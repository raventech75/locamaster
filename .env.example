# ============================================================
# LOCAMASTER — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles
# Ne jamais commiter le fichier .env
# ============================================================

# -----------------------------------------------------------
# SUPABASE (intégration future des leads)
# Créer un projet sur supabase.com, puis récupérer ces clés
# dans Settings > API
# -----------------------------------------------------------
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJxxxx...

# Service role key — utilisée UNIQUEMENT côté serveur (API route)
# Ne jamais l'exposer côté client (ne pas préfixer par PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...

# -----------------------------------------------------------
# MAKE (webhook pour automatisation des leads)
# Créer un scénario Make avec trigger "Webhooks > Custom webhook"
# Copier l'URL générée ici
# -----------------------------------------------------------
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxxxxxx

# -----------------------------------------------------------
# NOTIFICATION EMAIL (optionnel)
# Si tu veux recevoir un email à chaque lead sans Make
# Utiliser Resend, SendGrid ou Brevo
# -----------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxx
# NOTIFICATION_EMAIL=contact@locamaster.fr

# -----------------------------------------------------------
# SITE
# -----------------------------------------------------------
PUBLIC_SITE_URL=https://locamaster.fr
