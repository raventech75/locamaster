{
  "name": "locamaster-remotion",
  "version": "0.1.0",
  "private": true,
  "description": "Studio de production vidéo Locamaster — intros réseaux, stings logo, reveals d'offres (Remotion)",
  "scripts": {
    "dev": "remotion studio",
    "render:social": "remotion render src/index.ts SocialPromo out/social-promo.mp4",
    "render:logo": "remotion render src/index.ts LogoSting out/logo-sting.mp4",
    "render:offre": "remotion render src/index.ts OffreReveal out/offre-reveal.mp4",
    "render:all": "node render-all.mjs",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
