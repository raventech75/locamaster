---
const currentYear = new Date().getFullYear();
---

<footer class="bg-ink text-bg/80" role="contentinfo">
  <div class="container-site">
    <!-- Main footer -->
    <div class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex items-center gap-2.5 group mb-4" aria-label="Locamaster">
          <div class="w-8 h-8 bg-accent rounded flex items-center justify-center flex-shrink-0">
            <span class="font-display font-semibold text-white text-sm leading-none">L</span>
          </div>
          <span class="font-display font-medium text-lg tracking-tight text-white">Locamaster</span>
        </a>
        <p class="text-sm leading-relaxed text-bg/70 max-w-xs mt-3">
          Branding, photo et vidéo pour artisans et entreprises locales en Île-de-France.
          Exigence visuelle, approche humaine.
        </p>
        <!-- Réseaux sociaux -->
        <div class="flex items-center gap-3 mt-6">
          <a
            href="https://www.instagram.com/locamaster"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded border border-bg/20 flex items-center justify-center text-bg/60 hover:text-white hover:border-bg/50 transition-colors duration-200"
            aria-label="Instagram Locamaster"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="mailto:contact@locamaster.fr"
            class="w-9 h-9 rounded border border-bg/20 flex items-center justify-center text-bg/60 hover:text-white hover:border-bg/50 transition-colors duration-200"
            aria-label="Email Locamaster"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-sans font-medium tracking-widest uppercase text-bg/40 mb-4">Navigation</h3>
        <ul class="flex flex-col gap-2.5" role="list">
          {[
            { href: '/', label: 'Accueil' },
            { href: '/offres', label: 'Nos offres' },
            { href: '/realisations', label: 'Réalisations' },
            { href: '/a-propos', label: 'À propos' },
            { href: '/contact', label: 'Contact' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sm text-bg/70 hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-sans font-medium tracking-widest uppercase text-bg/40 mb-4">Contact</h3>
        <ul class="flex flex-col gap-3" role="list">
          <li>
            <a
              href="mailto:contact@locamaster.fr"
              class="text-sm text-bg/70 hover:text-white transition-colors duration-200 flex items-start gap-2"
            >
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              contact@locamaster.fr
            </a>
          </li>
          <li>
            <a
              href="tel:+33185094542"
              class="text-sm text-bg/70 hover:text-white transition-colors duration-200 flex items-start gap-2"
            >
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              01 85 09 45 42
            </a>
          </li>
          <li class="text-sm text-bg/60 flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Île-de-France
          </li>
        </ul>
        <a href="/contact" class="mt-5 inline-flex btn-primary text-sm py-2.5 px-5">
          Demander un devis
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-bg/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-bg/40 font-sans">
        © {currentYear} Locamaster. Tous droits réservés.
      </p>
      <div class="flex items-center gap-5">
        <a href="/mentions-legales" class="text-xs text-bg/40 hover:text-bg/70 transition-colors duration-200 font-sans">
          Mentions légales
        </a>
        <a href="/politique-confidentialite" class="text-xs text-bg/40 hover:text-bg/70 transition-colors duration-200 font-sans">
          Confidentialité
        </a>
      </div>
    </div>
  </div>
</footer>
