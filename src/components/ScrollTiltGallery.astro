---
// Galerie éditoriale inclinée au scroll (vanilla + GSAP ScrollTrigger).
// Les tuiles montent inclinées vers l'avant, se posent nettes au centre,
// puis basculent vers l'arrière en sortant. Inspiré d'un effet React
// (framer-motion) mais réécrit sans React, à la charte, avec de vraies images.
// La logique d'animation vit dans src/scripts/luxe.ts (data-tilt-tile).
interface Props {
  images?: string[];
  class?: string;
}

// Galerie sectorielle — restaurant, fleuriste, coiffeur, artisan, boulangerie, gastronomie, salon, antiquaire
const defaultImages = [
  'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80&auto=format', // restaurant Paris — salle élégante
  'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80&auto=format', // fleuriste — composition florale
  'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=80&auto=format', // coiffeur — coloration
  'https://images.unsplash.com/photo-1534398079543-7ae6d016b86a?w=800&q=80&auto=format', // artisan — savoir-faire manuel
  'https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800&q=80&auto=format', // boulangerie — pain artisan
  'https://images.unsplash.com/photo-1565299507177-b0ac66763828?w=800&q=80&auto=format', // gastronomie — dressage assiette
  'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&q=80&auto=format', // coiffure — résultat final
  'https://images.unsplash.com/photo-1533922922960-9fceb9ef4733?w=800&q=80&auto=format', // antiquaire — objets de collection
];

const { images = defaultImages, class: className = '' } = Astro.props;
---

<section class:list={['tilt-gallery relative w-full overflow-hidden', className]} aria-label="Galerie de réalisations">
  <div class="mx-auto grid w-full max-w-lg grid-cols-2 gap-8 px-6 py-[14vh]">
    {images.map((src, i) => (
      <figure
        class="tilt-tile relative z-10 m-0"
        data-tilt-tile
        data-side={i % 2 === 0 ? 'L' : 'R'}
        style="perspective:900px"
      >
        <div class="tilt-mover relative w-full overflow-hidden rounded-md aspect-[3/4]">
          <div
            class="tilt-img absolute inset-0 bg-cover bg-center"
            style={`background-image:url("${src}")`}
          ></div>
        </div>
      </figure>
    ))}
  </div>
</section>

<style>
  /* Filtre piloté par GSAP via variables CSS (état net par défaut, sans JS) */
  .tilt-mover {
    --tilt-blur: 0px;
    --tilt-bright: 1;
    --tilt-contrast: 1;
    filter: blur(var(--tilt-blur)) brightness(var(--tilt-bright)) contrast(var(--tilt-contrast));
    will-change: transform, filter;
  }
  .tilt-img {
    will-change: transform;
    backface-visibility: hidden;
  }
</style>
