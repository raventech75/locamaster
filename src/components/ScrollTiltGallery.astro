---
// Galerie éditoriale inclinée au scroll (vanilla + GSAP ScrollTrigger).
// Les tuiles montent inclinées vers l'avant, se posent nettes au centre,
// puis basculent vers l'arrière en sortant. Inspiré d'un effet React
// (framer-motion) mais réécrit sans React, à la charte, avec de vraies images.
// La logique d'animation vit dans src/scripts/luxe.ts (data-tilt-tile).
interface Props {
  images?: string[];
  class?: string;
}

// Par défaut : photos de contexte artisan/chantier (Unsplash, vérifiées).
const defaultImages = [
  'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1600585152220-90363fe7e115?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=800&q=80&auto=format',
  'https://images.unsplash.com/photo-1497366811353-6870744d04b2?w=800&q=80&auto=format',
];

const { images = defaultImages, class: className = '' } = Astro.props;
---

<section class:list={['tilt-gallery relative w-full overflow-hidden', className]} aria-label="Galerie de réalisations">
  <div class="mx-auto grid w-full max-w-lg grid-cols-2 gap-8 px-6 py-[14vh]">
    {images.map((src, i) => (
      <figure
        class="tilt-tile relative z-10 m-0"
        data-tilt-tile
        data-side={i % 2 === 0 ? 'L' : 'R'}
        style="perspective:900px"
      >
        <div class="tilt-mover relative w-full overflow-hidden rounded-md aspect-[3/4]">
          <div
            class="tilt-img absolute inset-0 bg-cover bg-center"
            style={`background-image:url("${src}")`}
          ></div>
        </div>
      </figure>
    ))}
  </div>
</section>

<style>
  /* Filtre piloté par GSAP via variables CSS (état net par défaut, sans JS) */
  .tilt-mover {
    --tilt-blur: 0px;
    --tilt-bright: 1;
    --tilt-contrast: 1;
    filter: blur(var(--tilt-blur)) brightness(var(--tilt-bright)) contrast(var(--tilt-contrast));
    will-change: transform, filter;
  }
  .tilt-img {
    will-change: transform;
    backface-visibility: hidden;
  }
</style>
