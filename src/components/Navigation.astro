---
interface Props {
  variant?: 'transparent' | 'solid';
}
const { variant = 'transparent' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/offres', label: 'Offres' },
  { href: '/realisations', label: 'Réalisations' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    variant === 'transparent' ? 'bg-transparent' : 'bg-bg/90 backdrop-blur-md border-b-2 border-ink',
  ]}
>
  <div class="container-site">
    <nav class="flex items-center justify-between h-16 md:h-20" aria-label="Navigation principale">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Locamaster — Accueil">
        <div class="flex items-center gap-2.5">
          <!-- Monogramme -->
          <div class="w-9 h-9 bg-accent border-2 border-ink rounded-lg flex items-center justify-center flex-shrink-0 group-hover:rotate-[-6deg] transition-transform duration-300">
            <span class="font-display font-bold text-ink text-base leading-none">L</span>
          </div>
          <span class="font-display font-bold text-xl tracking-tighter text-ink">
            Locamaster
          </span>
        </div>
      </a>

      <!-- Navigation desktop -->
      <ul class="hidden lg:flex items-center gap-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'relative px-4 py-2 text-sm font-sans font-semibold tracking-tight transition-colors duration-200',
                isActive(link.href)
                  ? 'text-ink'
                  : 'text-ink-2 hover:text-ink',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
              {isActive(link.href) && (
                <span class="absolute bottom-0.5 left-4 right-4 h-0.5 bg-accent rounded-full" aria-hidden="true"></span>
              )}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + mobile toggle -->
      <div class="flex items-center gap-3">
        <!-- Numéro téléphone visible desktop -->
        <a
          href="tel:+33185094542"
          class="hidden lg:inline-flex items-center gap-2 text-sm font-semibold text-ink hover:text-accent transition-colors duration-200"
          aria-label="Appeler Locamaster"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          01 85 09 45 42
        </a>
        <a
          href="/contact"
          class="hidden sm:inline-flex btn-accent text-sm py-2.5 px-5"
        >
          Devis gratuit
        </a>

        <!-- Toggle mobile -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden w-10 h-10 rounded-lg border-2 border-ink flex items-center justify-center text-ink hover:bg-accent transition-colors duration-200"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-bg border-t-2 border-ink"
    role="dialog"
    aria-modal="true"
    aria-label="Menu mobile"
  >
    <div class="container-site py-4">
      <ul class="flex flex-col gap-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'relative block px-4 py-3 text-base font-sans font-semibold rounded-lg transition-colors duration-200',
                isActive(link.href)
                  ? 'text-ink bg-accent-soft'
                  : 'text-ink-2 hover:text-ink hover:bg-surface',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
              {isActive(link.href) && (
                <span class="absolute left-4 bottom-1.5 right-4 h-0.5 bg-accent rounded-full" aria-hidden="true"></span>
              )}
            </a>
          </li>
        ))}
        <li class="pt-3 pb-1">
          <a href="/contact" class="btn-accent w-full justify-center text-sm">
            Demander un devis
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<!-- Spacer pour les pages avec nav solid -->
{variant === 'solid' && <div class="h-16 md:h-20" aria-hidden="true" />}

<script>
  // (Re)lié à chaque chargement — compatible Astro View Transitions
  function initNav() {
    // Toggle menu mobile
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    btn?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('hidden') === false;
      menu?.classList.toggle('hidden');
      iconMenu?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Header scroll behavior (transparent → solid) — seulement sur la home
    const header = document.getElementById('site-header');
    const heroSection = document.querySelector('[data-hero]');

    if (header && heroSection) {
      const solidClasses = ['bg-bg/90', 'backdrop-blur-md', 'border-b-2', 'border-ink'];
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            header.classList.remove(...solidClasses);
          } else {
            header.classList.add(...solidClasses);
          }
        },
        { threshold: 0.1, rootMargin: '-80px 0px 0px 0px' }
      );
      observer.observe(heroSection);
    }
  }

  document.addEventListener('astro:page-load', initNav);
</script>
