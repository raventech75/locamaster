---
// Bouton flottant WhatsApp / téléphone
// Remplace le numéro par le vrai numéro WhatsApp de Locamaster
const whatsappNumber = "33659835326"; // sans +, sans espaces
const whatsappMessage = encodeURIComponent("Bonjour, je souhaite en savoir plus sur vos prestations photo/vidéo.");
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
const phoneUrl = "tel:+33185094542";
---

<div id="floating-contact" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3" aria-label="Contact rapide">
  <!-- Label tooltip -->
  <div id="fc-label" class="hidden sm:block bg-ink text-white text-xs font-medium px-3 py-1.5 rounded-full opacity-0 translate-x-2 transition-all duration-200 pointer-events-none whitespace-nowrap">
    Écrivez-nous sur WhatsApp
  </div>

  <!-- Bouton principal WhatsApp -->
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    id="fc-whatsapp"
    class="group flex items-center justify-center w-14 h-14 rounded-full shadow-lg transition-all duration-300 hover:scale-110 active:scale-95"
    style="background-color: #25D366;"
    aria-label="Nous contacter sur WhatsApp"
  >
    <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Bulle pulsante (dot de notification) -->
  <span class="absolute top-0 right-0 w-3 h-3 rounded-full bg-accent animate-ping pointer-events-none" aria-hidden="true" style="top: -2px; right: -2px;"></span>
</div>

<style>
  #floating-contact {
    animation: fc-enter 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.5s both;
  }
  @keyframes fc-enter {
    from { opacity: 0; transform: translateY(20px) scale(0.8); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  #fc-whatsapp:hover ~ #fc-label,
  #fc-whatsapp:focus ~ #fc-label {
    opacity: 1;
    transform: translateX(0);
  }

  #floating-contact:hover #fc-label {
    opacity: 1;
    transform: translateX(0);
  }
</style>
