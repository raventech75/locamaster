---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page introuvable"
  description="Cette page n'existe pas."
  noIndex={true}
>
  <Navigation variant="solid" />
  <main id="main-content" class="flex-1 flex items-center justify-center">
    <div class="container-site section-pad text-center max-w-lg">
      <div class="font-display text-8xl font-medium text-border mb-6" aria-hidden="true">404</div>
      <h1 class="font-display text-2xl text-ink mb-4">Cette page n'existe pas.</h1>
      <p class="text-ink-2 mb-8 text-sm leading-relaxed">
        Le lien est peut-être cassé ou la page a été déplacée.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/contact" class="btn-secondary">Nous contacter</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
