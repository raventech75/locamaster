---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Offres from '../sections/Offres.astro';
import SessionDecouverte from '../sections/SessionDecouverte.astro';
import CTAFinale from '../sections/CTAFinale.astro';
import FAQ from '../sections/FAQ.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
---

<BaseLayout
  title="Tarifs photo, vidéo & branding — Packs artisans Île-de-France"
  description="Packs photo, vidéo et branding pour artisans et commerçants en Île-de-France. Tarifs transparents, livrables précis, sans surprise. Session découverte à partir de 190 € HT."
  canonical="/offres"
  breadcrumbs={[{ name: "Offres & Tarifs", url: "/offres" }]}
>
  <Navigation variant="solid" />
  <main id="main-content">

    <!-- Page hero -->
    <div class="bg-surface section-pad-sm">
      <div class="container-site max-w-3xl">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-line" aria-hidden="true" />
          <span class="section-label">Tarifs</span>
        </div>
        <h1 class="font-display text-ink mb-5">
          Des offres claires,<br />
          des résultats réels.
        </h1>
        <p class="text-lead max-w-xl mb-8">
          Tout est affiché. Pas de surprises en cours de route, pas de coûts cachés.
          Vous savez ce que vous payez avant de signer.
        </p>

        <!-- ROI framing avec compteurs animés -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-white rounded-xl border border-border p-5">
            <div class="font-display text-2xl font-medium text-accent mb-1"
              data-count="1" data-count-prefix="" data-count-suffix=" client">1 client</div>
            <div class="text-sm font-medium text-ink mb-1">nouveau client régulier</div>
            <div class="text-xs text-muted leading-relaxed">suffit à rentabiliser la session découverte à 190 €</div>
          </div>
          <div class="bg-white rounded-xl border border-border p-5">
            <div class="font-display text-2xl font-medium text-accent mb-1"
              data-count="42" data-count-prefix="+" data-count-suffix=" %">+42 %</div>
            <div class="text-sm font-medium text-ink mb-1">de clics Google Maps</div>
            <div class="text-xs text-muted leading-relaxed">en moyenne avec des photos professionnelles vs. photos téléphone</div>
          </div>
          <div class="bg-white rounded-xl border border-border p-5">
            <div class="font-display text-2xl font-medium text-accent mb-1"
              data-count="5" data-count-prefix="" data-count-suffix=" jours">5 jours</div>
            <div class="text-sm font-medium text-ink mb-1">délai de livraison</div>
            <div class="text-xs text-muted leading-relaxed">pour recevoir vos livrables finaux, retouchés et prêts à publier</div>
          </div>
        </div>
      </div>
    </div>

    <SessionDecouverte />
    <Offres showTitle={false} />

    <!-- Section "sur mesure" -->
    <section class="section-pad-sm bg-bg">
      <div class="container-site max-w-3xl">
        <div class="card-surface flex flex-col sm:flex-row items-start gap-6">
          <div class="flex-1">
            <h2 class="font-display text-xl font-medium text-ink mb-3">Projet sur mesure</h2>
            <p class="text-sm text-ink-2 leading-relaxed">
              Votre besoin sort des cases standards ? C'est souvent le cas.
              Un appel de 20 minutes suffit pour comprendre ce dont vous avez besoin
              et construire une proposition adaptée à votre situation.
            </p>
          </div>
          <a href="/contact" class="btn-primary flex-shrink-0">
            En discuter
          </a>
        </div>
      </div>
    </section>

    <LeadMagnet />
    <FAQ />
    <CTAFinale />
  </main>
  <Footer />
</BaseLayout>
