<div class="toast" id="toast"></div>
<div id="admin-cfg" data-token={token} style="display:none"></div>

<script is:inline>
const token = document.getElementById('admin-cfg').dataset.token;
let prospects = [];
let csvRows = [];

const STATUT_LABELS = {
  nouveau: 'Nouveau', contacte: 'Contacté', interesse: 'Intéressé',
  en_cours: 'En cours', signe: 'Signé', perdu: 'Perdu',
};

const SECTEUR_LABELS = {
  restaurateur: '🍽 Restaurateur', fleuriste: '🌸 Fleuriste', coiffeur: '✂️ Coiffeur',
  antiquaire: '🏺 Antiquaire', libraire: '📚 Libraire', boulanger: '🥖 Boulanger',
  architecte: '📐 Architecte', coach: '🧘 Coach', autre: '👤 Autre',
};

function apiUrl(path) { return `${path}?token=${token}`; }

// ── LOAD ──────────────────────────────────────────────
async function loadProspects() {
  try {
    const res = await fetch(apiUrl('/api/prospects'));
    prospects = await res.json();
    renderTable(prospects);
    updateStats(prospects);
    document.getElementById('last-update').textContent = 'Mis à jour à ' + new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
  } catch (e) { showToast('Erreur de chargement', 'error'); }
}

const PRIX_PIPELINE = { interesse: 950, en_cours: 950, signe: 950 };
const TODAY = new Date().toISOString().split('T')[0];

function updateStats(data) {
  document.getElementById('s-total').textContent = data.length;
  ['nouveau','contacte','interesse','signe'].forEach(s => {
    const el = document.getElementById('s-' + s);
    if (el) el.textContent = data.filter(p => p.statut === s).length;
  });
  // Pipeline
  const pipeline = data.reduce((sum, p) => sum + (PRIX_PIPELINE[p.statut] || 0), 0);
  document.getElementById('s-pipeline').textContent = pipeline > 0 ? pipeline.toLocaleString('fr-FR') + ' €' : '0 €';
  // Rappels en retard ou aujourd'hui
  const rappels = data.filter(p => p.rappel_le && p.rappel_le <= TODAY).length;
  document.getElementById('s-rappel').textContent = rappels || '0';
}

// ── FILTER ────────────────────────────────────────────
function filterTable() {
  const q = document.getElementById('search').value.toLowerCase();
  const statut = document.getElementById('filter-statut').value;
  const secteur = document.getElementById('filter-secteur').value;
  const rappel = document.getElementById('filter-rappel').value;
  const filtered = prospects.filter(p => {
    const matchQ = !q || [p.nom, p.entreprise, p.ville].some(v => v?.toLowerCase().includes(q));
    const matchS = statut === 'tous' || p.statut === statut;
    const matchSec = secteur === 'tous' || p.secteur === secteur;
    const matchR = rappel === 'tous' ? true
      : rappel === 'today' ? p.rappel_le === TODAY
      : rappel === 'overdue' ? (p.rappel_le && p.rappel_le < TODAY)
      : true;
    return matchQ && matchS && matchSec && matchR;
  });
  renderTable(filtered);
  renderKanban(filtered);
}

// ── RENDER ────────────────────────────────────────────
function daysSince(dateStr) {
  if (!dateStr) return 999;
  return Math.floor((Date.now() - new Date(dateStr).getTime()) / 86400000);
}

function renderTable(data) {
  const tbody = document.getElementById('tbody');
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="empty">Aucun prospect trouvé</td></tr>';
    return;
  }
  tbody.innerHTML = data.map(p => {
    const canRelance = p.email && p.email_envoye && p.statut === 'contacte' && daysSince(p.email_envoye_at) >= 4;
    let emailBtn = '';
    if (p.email) {
      emailBtn = p.email_envoye
        ? (canRelance
          ? `<button class="btn btn-sm btn-relance" onclick="sendRelance('${p.id}','${esc(p.nom)}','${esc(p.entreprise||'')}','${esc(p.email)}','${p.secteur||''}')">↩ Relancer</button>`
          : `<button class="btn btn-sm btn-email sent" disabled title="Email envoyé il y a ${daysSince(p.email_envoye_at)}j">✓ Envoyé</button>`)
        : `<button class="btn btn-sm btn-email" onclick="sendEmail('${p.id}','${esc(p.nom)}','${esc(p.entreprise||'')}','${esc(p.email)}','${p.secteur||''}')">✉ Email</button>`;
    }
    // Boutons appel/WhatsApp si pas d'email ou en complément
    const phoneClean = p.telephone ? '33' + p.telephone.replace(/[\s\-\.]/g,'').replace(/^\+33/,'').replace(/^0/,'') : null;
    const callBtn = p.telephone ? `<a href="tel:${esc(p.telephone)}" class="btn btn-sm" style="background:#e0f2fe;color:#0369a1;text-decoration:none">📞</a>` : '';
    const waBtn = phoneClean ? `<a href="https://wa.me/${phoneClean}?text=${encodeURIComponent('Bonjour, je suis Feridun de Locamaster. Je vous contacte au sujet de vos visuels professionnels.')}" target="_blank" rel="noopener" class="btn btn-sm" style="background:#dcfce7;color:#166534;text-decoration:none">💬</a>` : '';
    return `
    <tr>
      <td>
        <div style="font-weight:600;font-size:13px">
          ${esc(p.nom)}
          ${countCalls(p.notes) > 0 ? `<span class="call-badge">📞 ${countCalls(p.notes)}</span>` : ''}
          ${rappelBadge(p.rappel_le)}
        </div>
        ${p.entreprise ? `<div style="color:#78716c;font-size:12px">${esc(p.entreprise)}</div>` : ''}
        ${scoreHtml(p.score || computeScore(p))}
      </td>
      <td>${p.secteur ? (SECTEUR_LABELS[p.secteur] || p.secteur) : '<span style="color:#a8a29e">—</span>'}</td>
      <td>
        ${p.email ? `<a href="mailto:${esc(p.email)}" style="color:#1d4ed8;text-decoration:none;font-size:12px">${esc(p.email)}</a><br>` : ''}
        ${p.telephone ? `<span style="font-size:12px;color:#57534e">${esc(p.telephone)}</span>` : ''}
        ${!p.email && !p.telephone ? '<span style="color:#a8a29e">—</span>' : ''}
      </td>
      <td style="font-size:12px;color:#57534e">${p.ville || '—'}</td>
      <td>
        <select class="badge badge-${p.statut}" onchange="updateStatut('${p.id}', this.value)" style="border:none;background:transparent;cursor:pointer;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;outline:none">
          ${Object.entries(STATUT_LABELS).map(([v,l]) => `<option value="${v}" ${p.statut===v?'selected':''}>${l}</option>`).join('')}
        </select>
      </td>
      <td class="notes-cell" title="${esc(p.notes || '')}">${p.notes ? esc(p.notes) : '<span style="color:#a8a29e">—</span>'}</td>
      <td>
        <div class="actions">
          ${callBtn}${waBtn}${emailBtn}
          <button class="btn btn-sm btn-call" onclick="openCallModal('${p.id}','${esc(p.nom)}','${esc(p.entreprise||'')}','${esc(p.notes||'')}')">📞</button>
          <button class="btn btn-sm btn-ghost" onclick="openEdit('${p.id}')">✏</button>
          <button class="btn btn-sm btn-danger" onclick="deleteProspect('${p.id}')">✕</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function esc(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── ACTIONS ───────────────────────────────────────────
async function updateStatut(id, statut) {
  try {
    await fetch(apiUrl('/api/prospects'), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, statut }),
    });
    const p = prospects.find(x => x.id === id);
    if (p) p.statut = statut;
    updateStats(prospects);
    showToast('Statut mis à jour', 'success');
  } catch (e) { showToast('Erreur', 'error'); }
}

async function sendEmail(id, nom, entreprise, email, secteur) {
  if (!confirm(`Envoyer l'email de prospection à ${nom} (${email}) ?`)) return;
  try {
    const res = await fetch(apiUrl('/api/send-prospect-email'), {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prospectId: id, nom, entreprise, email, secteur, type: 'prospection' }),
    });
    if (!res.ok) throw new Error((await res.json()).error);
    const p = prospects.find(x => x.id === id);
    if (p) { p.email_envoye = true; p.email_envoye_at = new Date().toISOString(); p.statut = 'contacte'; }
    renderTable(prospects);
    updateStats(prospects);
    showToast(`Email envoyé à ${nom} !`, 'success');
  } catch (e) { showToast('Erreur : ' + e.message, 'error'); }
}

async function sendRelance(id, nom, entreprise, email, secteur) {
  if (!confirm(`Envoyer un email de relance à ${nom} (${email}) ?`)) return;
  try {
    const res = await fetch(apiUrl('/api/send-prospect-email'), {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prospectId: id, nom, entreprise, email, secteur, type: 'relance' }),
    });
    if (!res.ok) throw new Error((await res.json()).error);
    const p = prospects.find(x => x.id === id);
    if (p) {
      p.email_envoye_at = new Date().toISOString();
      const note = `Relance envoyée le ${new Date().toLocaleDateString('fr-FR')}`;
      p.notes = p.notes ? p.notes + ' · ' + note : note;
      await fetch(apiUrl('/api/prospects'), {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, notes: p.notes, email_envoye_at: p.email_envoye_at }),
      });
    }
    renderTable(prospects);
    showToast(`Relance envoyée à ${nom} !`, 'success');
  } catch (e) { showToast('Erreur : ' + e.message, 'error'); }
}

async function deleteProspect(id) {
  if (!confirm('Supprimer ce prospect ?')) return;
  try {
    await fetch(apiUrl('/api/prospects'), {
      method: 'DELETE', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    prospects = prospects.filter(p => p.id !== id);
    renderTable(prospects);
    updateStats(prospects);
    showToast('Prospect supprimé', 'success');
  } catch (e) { showToast('Erreur', 'error'); }
}

// ── MODAL AJOUT / ÉDITION ────────────────────────────
function openModal() {
  document.getElementById('modal-title').textContent = 'Ajouter un prospect';
  ['id','nom','entreprise','email','telephone','ville','notes'].forEach(f => {
    document.getElementById('f-' + f).value = '';
  });
  document.getElementById('f-statut').value = 'nouveau';
  document.getElementById('f-secteur').value = '';
  document.getElementById('f-source').value = 'manuel';
  document.getElementById('modal').classList.add('open');
}

function openEdit(id) {
  const p = prospects.find(x => x.id === id);
  if (!p) return;
  document.getElementById('modal-title').textContent = 'Modifier le prospect';
  document.getElementById('f-id').value = p.id;
  document.getElementById('f-nom').value = p.nom || '';
  document.getElementById('f-entreprise').value = p.entreprise || '';
  document.getElementById('f-email').value = p.email || '';
  document.getElementById('f-telephone').value = p.telephone || '';
  document.getElementById('f-ville').value = p.ville || '';
  document.getElementById('f-secteur').value = p.secteur || '';
  document.getElementById('f-statut').value = p.statut || 'nouveau';
  document.getElementById('f-source').value = p.source || 'manuel';
  document.getElementById('f-notes').value = p.notes || '';
  document.getElementById('modal').classList.add('open');
}

function closeModal() { document.getElementById('modal').classList.remove('open'); }

async function saveProspect() {
  const id = document.getElementById('f-id').value;
  const data = {
    nom: document.getElementById('f-nom').value.trim(),
    entreprise: document.getElementById('f-entreprise').value.trim(),
    email: document.getElementById('f-email').value.trim(),
    telephone: document.getElementById('f-telephone').value.trim(),
    ville: document.getElementById('f-ville').value.trim(),
    secteur: document.getElementById('f-secteur').value,
    statut: document.getElementById('f-statut').value,
    source: document.getElementById('f-source').value,
    notes: document.getElementById('f-notes').value.trim(),
  };
  if (!data.nom) { showToast('Le nom est requis', 'error'); return; }
  try {
    if (id) {
      const res = await fetch(apiUrl('/api/prospects'), {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, ...data }),
      });
      const updated = await res.json();
      const idx = prospects.findIndex(p => p.id === id);
      if (idx !== -1) prospects[idx] = updated;
    } else {
      const res = await fetch(apiUrl('/api/prospects'), {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const created = await res.json();
      prospects.unshift(created);
    }
    closeModal();
    renderTable(prospects);
    updateStats(prospects);
    showToast(id ? 'Prospect mis à jour' : 'Prospect ajouté', 'success');
  } catch (e) { showToast('Erreur lors de la sauvegarde', 'error'); }
}

// ── FINDER ────────────────────────────────────────────
function toggleFinder() {
  const body = document.getElementById('finder-body');
  const arrow = document.getElementById('finder-arrow');
  body.classList.toggle('open');
  arrow.textContent = body.classList.contains('open') ? '▲' : '▼';
}

