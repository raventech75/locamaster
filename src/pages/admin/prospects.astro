---
export const prerender = false;

const token = Astro.url.searchParams.get('token');
const adminToken = process.env.ADMIN_TOKEN ?? import.meta.env.ADMIN_TOKEN;

if (!adminToken || token !== adminToken) {
  return Astro.redirect('/404');
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prospects — Locamaster Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; background: #f5f5f4; color: #1c1917; font-size: 14px; min-height: 100vh; }

    .topbar { background: #1c1917; color: #fff; padding: 0 24px; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .topbar-brand { font-weight: 700; font-size: 15px; display: flex; align-items: center; gap: 8px; }
    .topbar-brand span { background: #f59e0b; color: #1c1917; width: 26px; height: 26px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 13px; }
    .topbar-right { font-size: 12px; color: #a8a29e; }
    .main { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }

    /* Stats */
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .stat { background: #fff; border: 1px solid #e7e5e4; border-radius: 10px; padding: 14px 16px; }
    .stat-value { font-size: 24px; font-weight: 700; line-height: 1; }
    .stat-label { font-size: 11px; color: #78716c; margin-top: 4px; text-transform: uppercase; letter-spacing: .05em; }
    .stat.s-nouveau .stat-value { color: #6366f1; }
    .stat.s-contacte .stat-value { color: #f59e0b; }
    .stat.s-interesse .stat-value { color: #10b981; }
    .stat.s-signe .stat-value { color: #059669; }
    .stat.s-pipeline .stat-value { color: #7c3aed; }
    .stat.s-rappel .stat-value { color: #dc2626; }

    /* Score */
    .score { display: inline-flex; gap: 2px; }
    .score-dot { width: 8px; height: 8px; border-radius: 50%; background: #e7e5e4; }
    .score-dot.on { background: #f59e0b; }
    .score-5 .score-dot.on { background: #dc2626; }
    .score-4 .score-dot.on { background: #f97316; }
    .score-3 .score-dot.on { background: #f59e0b; }
    .score-2 .score-dot.on { background: #84cc16; }
    .score-1 .score-dot.on { background: #22c55e; }

    /* Rappel */
    .rappel-badge { display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 10px; margin-left: 4px; }
    .rappel-today { background: #fee2e2; color: #dc2626; }
    .rappel-soon { background: #fef3c7; color: #92400e; }
    .rappel-future { background: #f0fdf4; color: #166534; }

    /* Kanban */
    .view-toggle { display: flex; gap: 4px; }
    .view-btn { padding: 6px 12px; border-radius: 6px; border: 1px solid #d6d3d1; background: #fff; font-size: 12px; font-weight: 600; cursor: pointer; }
    .view-btn.active { background: #1c1917; color: #fff; border-color: #1c1917; }
    .kanban-wrap { display: none; overflow-x: auto; padding-bottom: 8px; }
    .kanban-wrap.visible { display: flex; gap: 12px; }
    .kanban-col { min-width: 200px; flex: 1; }
    .kanban-col-header { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #78716c; padding: 8px 12px; background: #fafaf9; border: 1px solid #e7e5e4; border-radius: 10px 10px 0 0; display: flex; justify-content: space-between; }
    .kanban-col-body { border: 1px solid #e7e5e4; border-top: none; border-radius: 0 0 10px 10px; min-height: 120px; padding: 8px; display: flex; flex-direction: column; gap: 6px; background: #fff; }
    .kanban-card { background: #fafaf9; border: 1px solid #e7e5e4; border-radius: 8px; padding: 10px 12px; cursor: default; }
    .kanban-card:hover { border-color: #f59e0b; background: #fffbeb; }
    .kanban-card-name { font-size: 12px; font-weight: 700; margin-bottom: 3px; }
    .kanban-card-meta { font-size: 11px; color: #78716c; }
    .kanban-card-actions { display: flex; gap: 4px; margin-top: 6px; }

    /* Finder panel */
    .finder { background: #fff; border: 1px solid #e7e5e4; border-radius: 12px; padding: 16px 20px; margin-bottom: 20px; }
    .finder-toggle { display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; }
    .finder-toggle h3 { font-size: 14px; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .finder-toggle .badge-new { background: #fef3c7; color: #92400e; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px; }
    .finder-body { margin-top: 16px; display: none; }
    .finder-body.open { display: block; }
    .finder-row { display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end; }
    .finder-row .fg { display: flex; flex-direction: column; gap: 4px; }
    .finder-row label { font-size: 11px; font-weight: 600; color: #57534e; text-transform: uppercase; letter-spacing: .04em; }
    .finder-row select, .finder-row input { border: 1px solid #d6d3d1; border-radius: 8px; padding: 8px 11px; font-size: 13px; outline: none; background: #fff; }
    .finder-row select:focus, .finder-row input:focus { border-color: #f59e0b; }
    .finder-links { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .finder-link { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; border: 1px solid #d6d3d1; background: #fff; color: #1c1917; transition: background .15s; cursor: pointer; }
    .finder-link:hover { background: #fafaf9; }
    .finder-link.maps { background: #e8f5e9; border-color: #a5d6a7; color: #1b5e20; }
    .finder-link.insta { background: #fce4ec; border-color: #f48fb1; color: #880e4f; }
    .finder-link.pages { background: #e3f2fd; border-color: #90caf9; color: #0d47a1; }
    .finder-tip { margin-top: 12px; font-size: 12px; color: #78716c; background: #fafaf9; border-radius: 8px; padding: 10px 14px; line-height: 1.6; }
    /* Scraper auto */
    .scraper-sep { border: none; border-top: 1px solid #e7e5e4; margin: 18px 0; }
    .scraper-title { font-size: 13px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .scraper-badge { background: #dcfce7; color: #14532d; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px; }
    .scraper-status { font-size: 12px; color: #78716c; margin-top: 10px; min-height: 18px; }
    .scraper-status.running { color: #f59e0b; font-weight: 600; }
    .scraper-status.done { color: #059669; font-weight: 600; }
    .scraper-status.err { color: #dc2626; font-weight: 600; }
    .scraper-results { margin-top: 14px; display: none; }
    .scraper-results-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; flex-wrap: wrap; gap: 8px; }
    .scraper-results-header h4 { font-size: 13px; font-weight: 700; }
    .scraper-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .btn-auto { background: #dcfce7; color: #14532d; border: 1px solid #86efac; }
    .scraper-table-wrap { border: 1px solid #e7e5e4; border-radius: 10px; overflow: hidden; }
    .scraper-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .scraper-table th { background: #fafaf9; padding: 8px 12px; text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: .05em; color: #78716c; border-bottom: 1px solid #e7e5e4; }
    .scraper-table td { padding: 9px 12px; border-bottom: 1px solid #f5f5f4; vertical-align: middle; }
    .scraper-table tr:last-child td { border-bottom: none; }
    .scraper-table tr:hover td { background: #fafaf9; }
    .email-found { color: #059669; font-weight: 600; }
    .email-missing { color: #a8a29e; font-style: italic; }
    .contact-links { display: flex; flex-wrap: wrap; gap: 4px; }
    .contact-pill { display: inline-flex; align-items: center; gap: 3px; padding: 2px 7px; border-radius: 20px; font-size: 11px; font-weight: 600; text-decoration: none; white-space: nowrap; }
    .pill-tel { background: #e0f2fe; color: #0369a1; }
    .pill-wa { background: #dcfce7; color: #166534; }
    .pill-email { background: #ede9fe; color: #5b21b6; }
    .pill-ig { background: #fce7f3; color: #9d174d; }
    .pill-fb { background: #dbeafe; color: #1e40af; }
    .spinner { display: inline-block; width: 13px; height: 13px; border: 2px solid #e7e5e4; border-top-color: #f59e0b; border-radius: 50%; animation: spin .7s linear infinite; vertical-align: middle; margin-right: 4px; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Toolbar */
    .toolbar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 16px; }
    .toolbar select, .toolbar input { border: 1px solid #d6d3d1; border-radius: 8px; padding: 8px 12px; font-size: 13px; background: #fff; outline: none; }
    .toolbar select:focus, .toolbar input:focus { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,.15); }
    .toolbar input { flex: 1; min-width: 180px; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; border: none; cursor: pointer; transition: opacity .15s; }
    .btn:hover { opacity: .85; }
    .btn-primary { background: #f59e0b; color: #1c1917; }
    .btn-ghost { background: #fff; color: #1c1917; border: 1px solid #d6d3d1; }
    .btn-danger { background: #fee2e2; color: #dc2626; border: none; }
    .btn-sm { padding: 5px 10px; font-size: 12px; border-radius: 6px; }
    .btn-email { background: #dbeafe; color: #1d4ed8; }
    .btn-email.sent { background: #d1fae5; color: #065f46; cursor: default; opacity: .7; }
    .btn-relance { background: #fef3c7; color: #92400e; }
    .btn-import { background: #ede9fe; color: #5b21b6; border: 1px solid #c4b5fd; }

    /* Table */
    .table-wrap { background: #fff; border: 1px solid #e7e5e4; border-radius: 12px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 10px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: #78716c; background: #fafaf9; border-bottom: 1px solid #e7e5e4; }
    td { padding: 11px 14px; border-bottom: 1px solid #f5f5f4; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafaf9; }
    .empty { text-align: center; padding: 48px; color: #a8a29e; }

    /* Badges statut */
    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; white-space: nowrap; cursor: pointer; }
    .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; }
    .badge-nouveau { background: #ede9fe; color: #5b21b6; } .badge-nouveau::before { background: #6366f1; }
    .badge-contacte { background: #fef3c7; color: #92400e; } .badge-contacte::before { background: #f59e0b; }
    .badge-interesse { background: #d1fae5; color: #065f46; } .badge-interesse::before { background: #10b981; }
    .badge-en_cours { background: #dbeafe; color: #1e40af; } .badge-en_cours::before { background: #3b82f6; }
    .badge-signe { background: #bbf7d0; color: #14532d; } .badge-signe::before { background: #059669; }
    .badge-perdu { background: #fee2e2; color: #991b1b; } .badge-perdu::before { background: #dc2626; }

    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; display: none; align-items: center; justify-content: center; padding: 16px; }
    .modal-overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 14px; padding: 24px; width: 100%; max-width: 480px; max-height: 90vh; overflow-y: auto; }
    .modal h2 { font-size: 17px; font-weight: 700; margin-bottom: 20px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-col2 { grid-column: span 2; }
    label { display: block; font-size: 12px; font-weight: 600; color: #57534e; margin-bottom: 4px; }
    input[type=text], input[type=email], input[type=tel], input[type=file], select, textarea { width: 100%; border: 1px solid #d6d3d1; border-radius: 8px; padding: 9px 11px; font-size: 13px; outline: none; font-family: inherit; }
    input:focus, select:focus, textarea:focus { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,.15); }
    textarea { resize: vertical; min-height: 72px; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 8px; margin-top: 20px; }

    /* CSV modal */
    .csv-modal { max-width: 560px; }
    .csv-format { background: #f5f5f4; border-radius: 8px; padding: 10px 14px; font-size: 12px; font-family: monospace; margin-bottom: 12px; color: #57534e; line-height: 1.8; }
    .csv-preview { margin-top: 12px; }
    .csv-preview table { font-size: 12px; }
    .csv-preview th { font-size: 10px; }
    .csv-count { font-size: 12px; color: #78716c; margin-top: 8px; }
    .progress-bar { height: 6px; background: #e7e5e4; border-radius: 3px; margin-top: 12px; overflow: hidden; display: none; }
    .progress-bar-fill { height: 100%; background: #f59e0b; width: 0%; transition: width .3s; }

    .notes-cell { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #78716c; font-size: 12px; }
    .actions { display: flex; gap: 4px; flex-wrap: wrap; }
    .call-badge { display: inline-flex; align-items: center; gap: 3px; background: #fef3c7; color: #92400e; font-size: 10px; font-weight: 700; padding: 1px 5px; border-radius: 10px; margin-left: 4px; }
    .btn-call { background: #fef9c3; color: #713f12; border: 1px solid #fde68a; }
    /* Call modal */
    .call-modal { max-width: 380px; }
    .call-results { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 14px 0; }
    .call-opt { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border: 2px solid #e7e5e4; border-radius: 10px; cursor: pointer; font-size: 13px; font-weight: 600; transition: all .15s; }
    .call-opt:hover { border-color: #f59e0b; background: #fffbeb; }
    .call-opt.selected { border-color: #f59e0b; background: #fef3c7; }
    .call-opt input { display: none; }

    .toast { position: fixed; bottom: 20px; right: 20px; background: #1c1917; color: #fff; padding: 12px 18px; border-radius: 10px; font-size: 13px; font-weight: 500; z-index: 300; transform: translateY(20px); opacity: 0; transition: all .25s; pointer-events: none; max-width: 320px; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.success { background: #065f46; }
    .toast.error { background: #991b1b; }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-brand">
    <span>L</span>
    Locamaster · Prospects
  </div>
  <div class="topbar-right" id="last-update"></div>
</div>

<main class="main">

  <!-- Stats -->
  <div class="stats">
    <div class="stat s-total"><div class="stat-value" id="s-total">—</div><div class="stat-label">Total</div></div>
    <div class="stat s-nouveau"><div class="stat-value" id="s-nouveau">—</div><div class="stat-label">Nouveaux</div></div>
    <div class="stat s-contacte"><div class="stat-value" id="s-contacte">—</div><div class="stat-label">Contactés</div></div>
    <div class="stat s-interesse"><div class="stat-value" id="s-interesse">—</div><div class="stat-label">Intéressés</div></div>
    <div class="stat s-signe"><div class="stat-value" id="s-signe">—</div><div class="stat-label">Signés</div></div>
    <div class="stat s-pipeline"><div class="stat-value" id="s-pipeline">—</div><div class="stat-label">💰 Pipeline</div></div>
    <div class="stat s-rappel"><div class="stat-value" id="s-rappel">—</div><div class="stat-label">📅 À rappeler</div></div>
  </div>

  <!-- Finder panel -->
  <div class="finder">
    <div class="finder-toggle" onclick="toggleFinder()">
      <h3>🔍 Trouver des prospects <span class="badge-new">Nouveau</span></h3>
      <span id="finder-arrow">▼</span>
    </div>
    <div class="finder-body" id="finder-body">
      <div class="finder-row">
        <div class="fg">
          <label>Secteur</label>
          <select id="fd-secteur">
            <option value="restaurateurs">Restaurateurs</option>
            <option value="fleuristes">Fleuristes</option>
            <option value="coiffeurs">Coiffeurs</option>
            <option value="boulangeries">Boulangeries</option>
            <option value="antiquaires">Antiquaires</option>
            <option value="librairies">Librairies</option>
            <option value="architectes">Architectes</option>
            <option value="photographes">Photographes</option>
            <option value="commerces de proximité">Commerces de proximité</option>
          </select>
        </div>
        <div class="fg">
          <label>Ville / Arrondissement</label>
          <input type="text" id="fd-ville" value="Paris" placeholder="Paris 11e, Vincennes…" />
        </div>
        <button class="btn btn-primary" onclick="openFinderLinks()">Générer les liens →</button>
      </div>
      <div class="finder-links" id="finder-links" style="display:none">
        <a id="fl-maps" class="finder-link maps" target="_blank" rel="noopener">🗺 Google Maps</a>
        <a id="fl-pages" class="finder-link pages" target="_blank" rel="noopener">📋 Pages Jaunes</a>
        <a id="fl-insta" class="finder-link insta" target="_blank" rel="noopener">📷 Instagram</a>
        <button class="finder-link" onclick="copyScript()">📋 Copier script cold email</button>
      </div>
      <div class="finder-tip">
        💡 <strong>Méthode manuelle :</strong> Ouvre Google Maps → copie nom + adresse + email depuis la fiche → ajoute le prospect ou importe via CSV.<br>
        Ou utilise le <strong>Scraper automatique</strong> ci-dessous pour tout faire en un clic.
      </div>

      <!-- SCRAPER AUTOMATIQUE -->
      <hr class="scraper-sep" />
      <div class="scraper-title">
        🤖 Scraper automatique
        <span class="scraper-badge">Bêta</span>
      </div>
      <div class="finder-row">
        <div class="fg">
          <label>Secteur</label>
          <select id="sc-secteur">
            <optgroup label="🍽 Restauration / Commerce">
              <option value="restaurateurs">Restaurateurs</option>
              <option value="boulangeries pâtisseries">Boulangeries / Pâtisseries</option>
              <option value="fleuristes">Fleuristes</option>
              <option value="coiffeurs">Coiffeurs / Barbiers</option>
              <option value="instituts de beauté">Instituts de beauté</option>
              <option value="antiquaires brocantes">Antiquaires / Brocantes</option>
              <option value="librairies">Librairies</option>
              <option value="boutiques vêtements">Boutiques vêtements</option>
              <option value="épiceries fines">Épiceries fines</option>
            </optgroup>
            <optgroup label="🏗 BTP / Artisans">
              <option value="plombiers">Plombiers</option>
              <option value="électriciens">Électriciens</option>
              <option value="peintres en bâtiment">Peintres en bâtiment</option>
              <option value="menuisiers">Menuisiers</option>
              <option value="carreleurs">Carreleurs</option>
              <option value="maçons">Maçons</option>
              <option value="couvreurs">Couvreurs</option>
              <option value="serruriers">Serruriers</option>
              <option value="entreprises de rénovation">Entreprises rénovation</option>
              <option value="architectes d'intérieur">Architectes d'intérieur</option>
              <option value="décorateurs d'intérieur">Décorateurs d'intérieur</option>
              <option value="paysagistes">Paysagistes</option>
            </optgroup>
            <optgroup label="💼 Services / Libéraux">
              <option value="photographes">Photographes</option>
              <option value="agences immobilières">Agences immobilières</option>
              <option value="coaches sportifs">Coaches sportifs</option>
              <option value="thérapeutes">Thérapeutes / Ostéopathes</option>
              <option value="avocats">Avocats</option>
              <option value="comptables experts comptables">Comptables / Experts-comptables</option>
              <option value="agences de communication">Agences de communication</option>
              <option value="auto-écoles">Auto-écoles</option>
              <option value="garages automobiles">Garages automobiles</option>
            </optgroup>
          </select>
        </div>
        <div class="fg">
          <label>Ville</label>
          <input type="text" id="sc-ville" value="Paris" placeholder="Romainville, Vincennes…" style="width:140px" />
        </div>
        <div class="fg">
          <label>Code postal</label>
          <input type="text" id="sc-cp" placeholder="93230" style="width:90px" />
        </div>
        <div class="fg">
          <label>Nb résultats</label>
          <input type="number" id="sc-max" value="20" min="1" max="60" style="width:70px" />
        </div>
        <button class="btn btn-primary" onclick="runScraper()" id="sc-btn">🔍 Lancer la recherche</button>
      </div>
      <div class="scraper-status" id="sc-status"></div>

      <div class="scraper-results" id="sc-results">
        <div class="scraper-results-header">
          <h4 id="sc-count"></h4>
          <div class="scraper-actions">
            <button class="btn btn-sm btn-ghost" onclick="selectAllScraper()">Tout sélectionner</button>
            <button class="btn btn-sm btn-auto" onclick="importAndContactSelected()">⚡ Importer + contacter</button>
            <button class="btn btn-sm btn-ghost" onclick="importOnlySelected()">⬆ Importer seulement</button>
          </div>
        </div>
        <div class="scraper-table-wrap">
          <table class="scraper-table">
            <thead>
              <tr>
