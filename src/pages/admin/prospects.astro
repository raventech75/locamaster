// ── IMPORT CSV ────────────────────────────────────────
const CSV_COLS = ['nom','entreprise','secteur','email','telephone','ville'];

function parseCsv(text) {
  const lines = text.trim().split('\n').filter(l => l.trim());
  const sep = lines[0].includes(';') ? ';' : ',';
  const first = lines[0].toLowerCase();
  const hasHeader = CSV_COLS.some(c => first.includes(c));
  const dataLines = hasHeader ? lines.slice(1) : lines;
  return dataLines.map(line => {
    const parts = line.split(sep).map(s => s.trim().replace(/^["']|["']$/g,''));
    const row = {};
    CSV_COLS.forEach((col, i) => { row[col] = parts[i] || ''; });
    return row;
  }).filter(r => r.nom);
}

function loadCsvFile() {
  const file = document.getElementById('csv-file').files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('csv-text').value = e.target.result;
    previewCsv();
  };
  reader.readAsText(file);
}

function previewCsv() {
  const text = document.getElementById('csv-text').value;
  if (!text.trim()) { csvRows = []; document.getElementById('csv-preview').innerHTML = ''; document.getElementById('btn-import-go').disabled = true; return; }
  csvRows = parseCsv(text);
  const btn = document.getElementById('btn-import-go');
  if (!csvRows.length) {
    document.getElementById('csv-preview').innerHTML = '<p style="color:#dc2626;font-size:12px;margin-top:8px">Aucune ligne valide détectée.</p>';
    btn.disabled = true;
    return;
  }
  const preview = csvRows.slice(0, 3);
  document.getElementById('csv-preview').innerHTML = `
    <div class="csv-count">${csvRows.length} prospect(s) détecté(s) — aperçu des 3 premiers :</div>
    <div class="table-wrap" style="margin-top:8px">
      <table>
        <thead><tr>${CSV_COLS.map(c=>`<th>${c}</th>`).join('')}</tr></thead>
        <tbody>${preview.map(r=>`<tr>${CSV_COLS.map(c=>`<td>${esc(r[c])}</td>`).join('')}</tr>`).join('')}</tbody>
      </table>
    </div>`;
  btn.disabled = false;
}

function openImportModal() {
  document.getElementById('csv-file').value = '';
  document.getElementById('csv-text').value = '';
  document.getElementById('csv-preview').innerHTML = '';
  document.getElementById('btn-import-go').disabled = true;
  document.getElementById('import-progress').style.display = 'none';
  csvRows = [];
  document.getElementById('import-modal').classList.add('open');
}

function closeImportModal() { document.getElementById('import-modal').classList.remove('open'); }

async function runImport() {
  if (!csvRows.length) return;
  const btn = document.getElementById('btn-import-go');
  btn.disabled = true;
  btn.textContent = 'Import en cours…';
  const bar = document.getElementById('import-progress');
  const fill = document.getElementById('import-progress-fill');
  bar.style.display = 'block';
  let ok = 0, fail = 0;
  for (let i = 0; i < csvRows.length; i++) {
    const row = { ...csvRows[i], statut: 'nouveau', source: 'csv' };
    try {
      const res = await fetch(apiUrl('/api/prospects'), {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(row),
      });
      if (res.ok) { ok++; const created = await res.json(); prospects.unshift(created); }
      else fail++;
    } catch { fail++; }
    fill.style.width = Math.round(((i+1)/csvRows.length)*100) + '%';
  }
  closeImportModal();
  renderTable(prospects);
  updateStats(prospects);
  showToast(`${ok} prospect(s) importé(s)${fail ? `, ${fail} erreur(s)` : ''}`, ok ? 'success' : 'error');
}

// ── TOAST ─────────────────────────────────────────────
function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  setTimeout(() => { t.className = 'toast'; }, 3500);
}

// ── SCORE ─────────────────────────────────────────────
function computeScore(p) {
  let s = 0;
  if (!p.email) s += 2;
  if (!p.website && !p.notes?.includes('↗')) s += 1;
  if (p.telephone) s += 1;
  if (countCalls(p.notes) === 0) s += 1;
  return Math.min(5, Math.max(1, s));
}
function scoreHtml(score) {
  const s = score || 1;
  const label = ['','Faible','Bas','Moyen','Fort','Priorité'][s] || '';
  return `<div class="score score-${s}" title="Besoin estimé : ${label}">${[1,2,3,4,5].map(i => `<span class="score-dot${i<=s?' on':''}"></span>`).join('')}</div>`;
}

// ── RAPPEL ────────────────────────────────────────────
function rappelBadge(date) {
  if (!date) return '';
  if (date < TODAY) return `<span class="rappel-badge rappel-today">🔴 ${formatDate(date)}</span>`;
  if (date === TODAY) return `<span class="rappel-badge rappel-today">📅 Aujourd'hui</span>`;
  const diff = Math.ceil((new Date(date) - new Date(TODAY)) / 86400000);
  if (diff <= 3) return `<span class="rappel-badge rappel-soon">📅 J+${diff}</span>`;
  return `<span class="rappel-badge rappel-future">📅 ${formatDate(date)}</span>`;
}
function formatDate(iso) {
  const [y,m,d] = iso.split('-');
  return `${d}/${m}`;
}

// ── KANBAN ────────────────────────────────────────────
let currentView = 'table';
const KANBAN_COLS = [
  { key: 'nouveau', label: 'Nouveau', color: '#6366f1' },
  { key: 'contacte', label: 'Contacté', color: '#f59e0b' },
  { key: 'interesse', label: 'Intéressé', color: '#10b981' },
  { key: 'en_cours', label: 'En cours', color: '#3b82f6' },
  { key: 'signe', label: 'Signé 🎉', color: '#059669' },
  { key: 'perdu', label: 'Perdu', color: '#dc2626' },
];

function setView(view) {
  currentView = view;
  document.getElementById('table-wrap').style.display = view === 'table' ? '' : 'none';
  const kw = document.getElementById('kanban-wrap');
  kw.classList.toggle('visible', view === 'kanban');
  document.getElementById('btn-view-table').classList.toggle('active', view === 'table');
  document.getElementById('btn-view-kanban').classList.toggle('active', view === 'kanban');
  if (view === 'kanban') renderKanban(prospects);
}

function renderKanban(data) {
  const wrap = document.getElementById('kanban-wrap');
  if (!wrap.classList.contains('visible')) return;
  wrap.innerHTML = KANBAN_COLS.map(col => {
    const cards = data.filter(p => p.statut === col.key);
    return `
    <div class="kanban-col">
      <div class="kanban-col-header" style="border-top:3px solid ${col.color}">
        <span>${col.label}</span>
        <span style="background:${col.color}20;color:${col.color};padding:1px 7px;border-radius:10px;font-size:10px">${cards.length}</span>
      </div>
      <div class="kanban-col-body">
        ${cards.length === 0 ? '<div style="text-align:center;color:#a8a29e;font-size:12px;padding:16px">Vide</div>' : ''}
        ${cards.map(p => `
          <div class="kanban-card">
            <div class="kanban-card-name">${esc(p.nom)}</div>
            ${p.entreprise ? `<div class="kanban-card-meta">${esc(p.entreprise)}</div>` : ''}
            <div class="kanban-card-meta" style="margin-top:3px">
              ${p.telephone ? `<a href="tel:${esc(p.telephone)}" style="color:#0369a1;text-decoration:none">📞</a> ` : ''}
              ${p.email ? `<a href="mailto:${esc(p.email)}" style="color:#5b21b6;text-decoration:none">✉</a> ` : ''}
              ${p.ville ? `· ${esc(p.ville)}` : ''}
              ${rappelBadge(p.rappel_le)}
            </div>
            ${scoreHtml(p.score || computeScore(p))}
            <div class="kanban-card-actions">
              ${KANBAN_COLS.filter(c => c.key !== col.key).slice(0,2).map(c =>
                `<button onclick="updateStatut('${p.id}','${c.key}')" style="font-size:10px;padding:3px 7px;border:1px solid #e7e5e4;background:#fff;border-radius:5px;cursor:pointer" title="→ ${c.label}">→ ${c.label}</button>`
              ).join('')}
              <button onclick="openCallModal('${p.id}','${esc(p.nom)}','${esc(p.entreprise||'')}','${esc(p.notes||')}')" style="font-size:10px;padding:3px 7px;border:1px solid #e7e5e4;background:#fff;border-radius:5px;cursor:pointer">📞</button>
            </div>
          </div>`).join('')}
      </div>
    </div>`;
  }).join('');
}

// ── EXPORT CSV ────────────────────────────────────────
function exportCsv() {
  const data = prospects;
  const cols = ['nom','entreprise','secteur','email','telephone','ville','statut','source','notes','rappel_le','created_at'];
  const header = cols.join(';');
  const rows = data.map(p => cols.map(c => `"${(p[c]||'').toString().replace(/"/g,'""')}"`).join(';'));
  const csv = [header, ...rows].join('\n');
  const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `prospects-locamaster-${TODAY}.csv`;
  a.click();
  showToast('Export téléchargé', 'success');
}

document.getElementById('modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
document.getElementById('import-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeImportModal(); });
document.getElementById('call-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeCallModal(); });

// ── LOG APPEL ─────────────────────────────────────────
const CALL_RESULTS = {
  pas_repondu: 'Pas répondu',
  messagerie: 'Messagerie',
  interesse: 'Intéressé',
  pas_interesse: 'Pas intéressé',
  rappeler: 'À rappeler',
  rdv_pris: '🎯 RDV pris',
};
const CALL_STATUT = {
  interesse: 'interesse',
  rdv_pris: 'en_cours',
  pas_interesse: 'perdu',
};

let callSelectedResult = null;

function countCalls(notes) {
  if (!notes) return 0;
  return (notes.match(/📞 Appel/g) || []).length;
}

function openCallModal(id, nom, entreprise, notes) {
  document.getElementById('call-prospect-id').value = id;
  document.getElementById('call-prospect-notes').value = notes;
  document.getElementById('call-prospect-name').textContent = entreprise ? `${nom} · ${entreprise}` : nom;
  document.getElementById('call-note').value = '';
  callSelectedResult = null;
  document.querySelectorAll('.call-opt').forEach(el => el.classList.remove('selected'));
  document.getElementById('call-modal').classList.add('open');
}

function closeCallModal() {
  document.getElementById('call-modal').classList.remove('open');
}

function selectCallResult(el, value) {
  document.querySelectorAll('.call-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  callSelectedResult = value;
  // Afficher le date picker seulement pour "À rappeler"
  document.getElementById('call-rappel-wrap').style.display = value === 'rappeler' ? '' : 'none';
  if (value === 'rappeler') {
    // Proposer dans 5 jours par défaut
    const d = new Date(); d.setDate(d.getDate() + 5);
    document.getElementById('call-rappel-date').value = d.toISOString().split('T')[0];
  }
}

async function saveCall() {
  if (!callSelectedResult) { showToast('Sélectionne un résultat', 'error'); return; }
  const id = document.getElementById('call-prospect-id').value;
  const existingNotes = document.getElementById('call-prospect-notes').value;
  const extraNote = document.getElementById('call-note').value.trim();
  const date = new Date().toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit' });
  const label = CALL_RESULTS[callSelectedResult];
  const callEntry = `📞 Appel ${date} · ${label}${extraNote ? ` · ${extraNote}` : ''}`;
  const newNotes = existingNotes ? existingNotes + '\n' + callEntry : callEntry;

  const rappelDate = callSelectedResult === 'rappeler'
    ? document.getElementById('call-rappel-date').value || null
    : null;
  const updates = { id, notes: newNotes };
  if (CALL_STATUT[callSelectedResult]) updates.statut = CALL_STATUT[callSelectedResult];
  if (rappelDate) updates.rappel_le = rappelDate;

  try {
    const res = await fetch(apiUrl('/api/prospects'), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(updates),
    });
    if (!res.ok) throw new Error();
    const idx = prospects.findIndex(p => p.id === id);
    if (idx !== -1) {
      prospects[idx].notes = newNotes;
      if (updates.statut) prospects[idx].statut = updates.statut;
      if (rappelDate) prospects[idx].rappel_le = rappelDate;
    }
    closeCallModal();
    renderTable(prospects);
    updateStats(prospects);
    showToast(`Appel enregistré : ${label}`, 'success');
  } catch { showToast('Erreur lors de l\'enregistrement', 'error'); }
}

// ── SCRAPER ───────────────────────────────────────────
let scraperResults = [];

async function runScraper() {
  const secteur = document.getElementById('sc-secteur').value;
  const ville = document.getElementById('sc-ville').value.trim() || 'Paris';
  const codePostal = document.getElementById('sc-cp').value.trim() || null;
  const max = parseInt(document.getElementById('sc-max').value) || 20;
  const btn = document.getElementById('sc-btn');
  const status = document.getElementById('sc-status');
  const resultsDiv = document.getElementById('sc-results');

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Recherche en cours…';
  status.className = 'scraper-status running';
  status.innerHTML = `<span class="spinner"></span> Recherche de ${secteur} à ${ville} sur Google Maps + extraction des emails…`;
  resultsDiv.style.display = 'none';

  try {
    const res = await fetch(apiUrl('/api/scrape-prospects'), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ secteur, ville, codePostal, max }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Erreur serveur');

    scraperResults = data.results || [];
    const withEmail = scraperResults.filter(r => r.email).length;

    status.className = 'scraper-status done';
    status.textContent = `✓ ${scraperResults.length} commerce(s) trouvé(s) · ${withEmail} email(s) extrait(s) automatiquement`;

    renderScraperResults();
    resultsDiv.style.display = 'block';
    document.getElementById('sc-count').textContent = `${scraperResults.length} résultats — ${withEmail} avec email`;
  } catch (e) {
    status.className = 'scraper-status err';
    status.textContent = '✗ Erreur : ' + e.message;
  } finally {
    btn.disabled = false;
    btn.textContent = '🔍 Lancer la recherche';
  }
}

function renderScraperResults() {
  const tbody = document.getElementById('sc-tbody');
  tbody.innerHTML = scraperResults.map((r, i) => {
    const hasContact = r.email || r.telephone;
    const pills = [];
    if (r.email) pills.push(`<a href="mailto:${esc(r.email)}" class="contact-pill pill-email" title="${esc(r.email)}">✉ Email</a>`);
    if (r.telephone) {
      pills.push(`<a href="tel:${esc(r.telephone)}" class="contact-pill pill-tel">📞 ${esc(r.telephone)}</a>`);
      if (r.telephone_wa) pills.push(`<a href="https://wa.me/${esc(r.telephone_wa)}" target="_blank" rel="noopener" class="contact-pill pill-wa">💬 WhatsApp</a>`);
    }
    if (r.instagram) pills.push(`<a href="${esc(r.instagram)}" target="_blank" rel="noopener" class="contact-pill pill-ig">📷 Instagram</a>`);
    if (r.facebook) pills.push(`<a href="${esc(r.facebook)}" target="_blank" rel="noopener" class="contact-pill pill-fb">Facebook</a>`);
    return `
    <tr>
      <td><input type="checkbox" class="sc-row-check" data-idx="${i}" ${hasContact ? 'checked' : ''} /></td>
      <td><strong>${esc(r.nom)}</strong></td>
      <td><div class="contact-links">${pills.length ? pills.join('') : '<span class="email-missing">Aucun contact</span>'}</div></td>
      <td style="color:#57534e;font-size:11px">${esc(r.ville)}</td>
      <td>${r.website ? `<a href="${esc(r.website)}" target="_blank" rel="noopener" style="color:#1d4ed8;font-size:11px;text-decoration:none">↗ Site</a>` : '<span class="email-missing">—</span>'}</td>
    </tr>`;
  }).join('');
}

function selectAllScraper() {
  document.querySelectorAll('.sc-row-check').forEach(cb => cb.checked = true);
  document.getElementById('sc-check-all').checked = true;
}

function toggleAllScraper(checked) {
  document.querySelectorAll('.sc-row-check').forEach(cb => cb.checked = checked);
}

function getSelectedScraper() {
  return [...document.querySelectorAll('.sc-row-check:checked')]
    .map(cb => scraperResults[parseInt(cb.dataset.idx)])
    .filter(Boolean);
}

async function importOnlySelected() {
  const selected = getSelectedScraper();
  if (!selected.length) { showToast('Sélectionne au moins un prospect', 'error'); return; }
  let ok = 0;
  for (const r of selected) {
    try {
      const res = await fetch(apiUrl('/api/prospects'), {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nom: r.nom, entreprise: r.entreprise, email: r.email,
          telephone: r.telephone, ville: r.ville, secteur: r.secteur,
          source: 'google-maps', statut: 'nouveau',
        }),
      });
      if (res.ok) { ok++; const created = await res.json(); prospects.unshift(created); }
    } catch {}
  }
  renderTable(prospects);
  updateStats(prospects);
  showToast(`${ok} prospect(s) importé(s)`, 'success');
}

async function importAndContactSelected() {
  const selected = getSelectedScraper();
  if (!selected.length) { showToast('Sélectionne au moins un prospect', 'error'); return; }
  const withEmail = selected.filter(r => r.email);
  const withPhoneOnly = selected.filter(r => !r.email && r.telephone);
  if (!confirm(`Importer ${selected.length} prospect(s) ?\n→ ${withEmail.length} avec email (envoi auto)\n→ ${withPhoneOnly.length} sans email (statut "À appeler")`)) return;

  let imported = 0, emailed = 0;
  for (const r of selected) {
    try {
      const statut = r.email ? 'nouveau' : 'nouveau';
      const notes = !r.email && r.telephone
        ? `📞 À appeler${r.telephone_wa ? ` · WhatsApp : wa.me/${r.telephone_wa}` : ''}${r.instagram ? ` · Instagram : ${r.instagram}` : ''}`
        : (r.instagram ? `Instagram : ${r.instagram}` : '');
      const res = await fetch(apiUrl('/api/prospects'), {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nom: r.nom, entreprise: r.entreprise, email: r.email,
          telephone: r.telephone, ville: r.ville, secteur: r.secteur,
          source: 'google-maps', statut, notes: notes || null,
        }),
      });
      if (!res.ok) continue;
      const created = await res.json();
      prospects.unshift(created);
      imported++;

      if (r.email) {
        const emailRes = await fetch(apiUrl('/api/send-prospect-email'), {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            prospectId: created.id, nom: r.nom, entreprise: r.entreprise,
            email: r.email, secteur: r.secteur, type: 'prospection',
          }),
        });
        if (emailRes.ok) {
          const idx = prospects.findIndex(p => p.id === created.id);
          if (idx !== -1) { prospects[idx].email_envoye = true; prospects[idx].statut = 'contacte'; }
          emailed++;
        }
      }
    } catch {}
  }
  renderTable(prospects);
  updateStats(prospects);
  showToast(`✓ ${imported} importé(s) · ${emailed} email(s) envoyé(s)`, 'success');
}

loadProspects();
</script>

