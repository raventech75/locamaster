---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

// Lire le param ?offre= pour pré-sélectionner une offre
const offreParam = Astro.url.searchParams.get('offre') || '';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Devis gratuit Locamaster",
  "description": "Demandez votre devis photo, vidéo ou branding à Locamaster pour artisans en Île-de-France.",
  "url": "https://www.locamaster.fr/contact",
  "mainEntity": {
    "@type": "LocalBusiness",
    "@id": "https://www.locamaster.fr/#localbusiness",
    "name": "Locamaster",
    "telephone": "+33185094542",
    "email": "contact@locamaster.fr"
  }
};
---

<BaseLayout
  title="Devis gratuit — Photo, vidéo & branding pour artisans Île-de-France"
  description="Demandez votre devis personnalisé à Locamaster. Photo professionnelle, vidéo réseaux sociaux et branding pour artisans et commerçants en Île-de-France. Réponse sous 24h."
  canonical="/contact"
  breadcrumbs={[{ name: "Contact & Devis", url: "/contact" }]}
  schema={schema}
>
  <Navigation variant="solid" />
  <main id="main-content">
    <div class="section-pad bg-bg">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

          <!-- Gauche — texte -->
          <div class="lg:col-span-2">
            <div class="flex items-center gap-3 mb-5">
              <span class="accent-line" aria-hidden="true" />
              <span class="section-label">Contact</span>
            </div>
            <h1 class="font-display text-ink mb-5">
              Parlons de<br />votre projet.
            </h1>
            <p class="text-ink-2 leading-relaxed mb-8">
              Remplissez ce formulaire et je vous réponds sous 24h avec
              une première réflexion sur votre besoin — pas un devis automatisé impersonnel.
            </p>

            <!-- Infos de contact -->
            <div class="flex flex-col gap-4 mb-8">
              <a href="mailto:contact@locamaster.fr" class="flex items-center gap-3 text-sm text-ink-2 hover:text-ink transition-colors duration-200 group">
                <div class="w-9 h-9 bg-surface rounded-lg border border-border flex items-center justify-center flex-shrink-0 group-hover:border-accent/40 transition-colors duration-200">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                contact@locamaster.fr
              </a>
              <a href="tel:+33185094542" class="flex items-center gap-3 text-sm text-ink-2 hover:text-ink transition-colors duration-200 group">
                <div class="w-9 h-9 bg-surface rounded-lg border border-border flex items-center justify-center flex-shrink-0 group-hover:border-accent/40 transition-colors duration-200">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                01 85 09 45 42
              </a>
              <div class="flex items-center gap-3 text-sm text-ink-2">
                <div class="w-9 h-9 bg-surface rounded-lg border border-border flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                Île-de-France
              </div>
            </div>

            <!-- Rassurances -->
            <div class="card-surface text-sm text-ink-2 leading-relaxed">
              <p class="font-medium text-ink mb-2">Ce que vous pouvez attendre :</p>
              <ul class="flex flex-col gap-1.5">
                {[
                  'Réponse sous 24h (souvent moins)',
                  'Pas de démarchage agressif',
                  'Une vraie réflexion sur votre besoin',
                  'Devis clair et sans engagement',
                ].map((item) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-3.5 h-3.5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Droite — formulaire -->
          <div class="lg:col-span-3">
            <div class="bg-white rounded-2xl border border-border p-8 md:p-10 shadow-sm">

              <form
                id="contact-form"
                action="/api/contact"
                method="POST"
                novalidate
              >
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
                  <!-- Nom -->
                  <div>
                    <label class="form-label" for="nom">Votre nom *</label>
                    <input
                      type="text"
                      id="nom"
                      name="nom"
                      class="form-input"
                      placeholder="Prénom Nom"
                      required
                      autocomplete="name"
                    />
                  </div>

                  <!-- Entreprise -->
                  <div>
                    <label class="form-label" for="entreprise">Votre entreprise</label>
                    <input
                      type="text"
                      id="entreprise"
                      name="entreprise"
                      class="form-input"
                      placeholder="Nom de votre société"
                      autocomplete="organization"
                    />
                  </div>

                  <!-- Email -->
                  <div>
                    <label class="form-label" for="email">Email *</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      class="form-input"
                      placeholder="vous@exemple.fr"
                      required
                      autocomplete="email"
                    />
                  </div>

                  <!-- Téléphone -->
                  <div>
                    <label class="form-label" for="telephone">Téléphone</label>
                    <input
                      type="tel"
                      id="telephone"
                      name="telephone"
                      class="form-input"
                      placeholder="06 12 34 56 78"
                      autocomplete="tel"
                    />
                  </div>
                </div>

                <!-- Type de besoin -->
                <div class="mb-5">
                  <label class="form-label" for="besoin">Votre besoin principal *</label>
                  <div class="relative">
                    <select
                      id="besoin"
                      name="besoin"
                      class="form-select"
                      required
                    >
                      <option value="">Choisir...</option>
                      <option value="session-decouverte" selected={offreParam === 'session-decouverte'}>
                        Session Découverte Signature — 190 € HT
                      </option>
                      <option value="royal-starter" selected={offreParam === 'royal-starter'}>
                        Pack Royal Starter — à partir de 1 000 € HT
                      </option>
                      <option value="branding-pro" selected={offreParam === 'branding-pro'}>
                        Pack Branding Pro — à partir de 2 200 € HT
                      </option>
                      <option value="premium-artisan" selected={offreParam === 'premium-artisan'}>
                        Pack Premium Artisan — à partir de 4 000 € HT
                      </option>
                      <option value="social-starter" selected={offreParam === 'social-starter'}>
                        Abonnement Social Starter — 300 € HT / mois
                      </option>
                      <option value="social-pro" selected={offreParam === 'social-pro'}>
                        Abonnement Social Pro — 500 € HT / mois
                      </option>
                      <option value="social-elite" selected={offreParam === 'social-elite'}>
                        Abonnement Social Elite — 800 € HT / mois
                      </option>
                      <option value="sur-mesure">Projet sur mesure</option>
                      <option value="information">Demande d'information</option>
                    </select>
                    <!-- Chevron -->
                    <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                      <svg class="w-4 h-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </div>
                  </div>
                </div>

                <!-- Budget -->
                <div class="mb-5">
                  <label class="form-label" for="budget">Budget estimé (optionnel)</label>
                  <div class="relative">
                    <select id="budget" name="budget" class="form-select">
                      <option value="">Non précisé</option>
                      <option value="moins-500">Moins de 500 € HT</option>
                      <option value="500-1500">500 à 1 500 € HT</option>
                      <option value="1500-3000">1 500 à 3 000 € HT</option>
                      <option value="3000-5000">3 000 à 5 000 € HT</option>
                      <option value="plus-5000">Plus de 5 000 € HT</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                      <svg class="w-4 h-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </div>
                  </div>
                </div>

                <!-- Message -->
                <div class="mb-7">
                  <label class="form-label" for="message">Décrivez votre projet *</label>
                  <textarea
                    id="message"
                    name="message"
                    class="form-input resize-none"
                    rows="4"
                    placeholder="Votre activité, ce que vous cherchez à mettre en valeur, vos objectifs..."
                    required
                  />
                </div>

                <!-- Honeypot anti-spam (caché) -->
                <div class="hidden" aria-hidden="true">
                  <input type="text" name="_hp" tabindex="-1" autocomplete="off" />
                </div>

                <!-- Submit -->
                <button
                  type="submit"
                  id="submit-btn"
                  class="btn-primary w-full justify-center text-base py-4"
                >
                  <span id="btn-label">Envoyer — réponse sous 24h</span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </button>

                <!-- Messages de retour -->
                <div id="form-success" class="hidden mt-5 p-4 bg-emerald-50 border border-emerald-200 rounded-lg text-sm text-emerald-800">
                  Votre message a bien été envoyé. Je vous réponds dans les 24h.
                </div>
                <div id="form-error" class="hidden mt-5 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800">
                  Une erreur s'est produite. Vous pouvez m'écrire directement à
                  <a href="mailto:contact@locamaster.fr" class="underline">contact@locamaster.fr</a>.
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // (Re)lié à chaque chargement — compatible Astro View Transitions
  function initContactForm() {
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (!form) return;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validation minimale côté client
    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((field) => {
      const el = field as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
      if (!el.value.trim()) {
        valid = false;
        el.classList.add('border-red-400', 'ring-1', 'ring-red-200');
      } else {
        el.classList.remove('border-red-400', 'ring-1', 'ring-red-200');
      }
    });
    if (!valid) return;

    // Loading state
    submitBtn.disabled = true;
    if (btnLabel) btnLabel.textContent = 'Envoi en cours...';

    try {
      const formData = new FormData(form);
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(formData)),
      });

      if (response.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
        document.dispatchEvent(new CustomEvent('contact:success'));
        successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        throw new Error('Erreur serveur');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
    } finally {
      submitBtn.disabled = false;
      if (btnLabel) btnLabel.textContent = 'Envoyer ma demande';
    }
  });
  }

  document.addEventListener('astro:page-load', initContactForm);
</script>
