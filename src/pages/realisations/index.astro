---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/portfolio/ProjectCard.astro';
import ScrollTiltGallery from '../../components/ScrollTiltGallery.astro';
import { projets } from '../../data/projets';

const categories = [
  { id: 'all', label: 'Tout voir' },
  { id: 'pack', label: 'Pack complet' },
  { id: 'video', label: 'Vidéo' },
  { id: 'photo', label: 'Photo' },
  { id: 'branding', label: 'Branding' },
];
---

<BaseLayout
  title="Réalisations & Portfolio"
  description="Portfolio de branding, photo et vidéo pour artisans et entreprises locales en Île-de-France. Plombiers, cuisinistes, menuisiers, entreprises de rénovation."
  canonical="/realisations"
>
  <Navigation variant="solid" />
  <main id="main-content">

    <!-- Hero page -->
    <div class="bg-surface section-pad-sm">
      <div class="container-site">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-line" aria-hidden="true" />
          <span class="section-label">Portfolio</span>
        </div>
        <h1 class="font-display text-ink mb-5 max-w-xl">
          Des résultats concrets,<br />
          pas des promesses.
        </h1>
        <p class="text-lead max-w-lg">
          Chaque projet présenté ici correspond à un vrai client, un vrai besoin,
          et un vrai résultat. Portfolio en construction — mis à jour régulièrement.
        </p>
      </div>
    </div>

    <!-- Galerie éditoriale inclinée au scroll -->
    <div class="bg-ink">
      <ScrollTiltGallery />
    </div>

    <!-- Filtres -->
    <div class="bg-bg border-b border-border sticky top-16 md:top-18 z-30">
      <div class="container-site">
        <div class="flex items-center gap-2 py-3 overflow-x-auto scrollbar-hide">
          {categories.map((cat) => (
            <button
              class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-sans font-medium transition-colors duration-200 border"
              data-filter={cat.id}
              aria-pressed={cat.id === 'all' ? 'true' : 'false'}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Grille -->
    <section class="section-pad-sm bg-bg" aria-label="Portfolio">
      <div class="container-site">
        <div class="portfolio-grid" id="portfolio-grid">
          {projets.map((projet) => (
            <div
              class="portfolio-item"
              data-categorie={projet.categorie}
            >
              <ProjectCard projet={projet} />
            </div>
          ))}
        </div>

        <!-- Message quand aucun résultat (masqué par défaut) -->
        <div id="no-results" class="hidden text-center py-16">
          <p class="text-muted text-sm">Aucun projet dans cette catégorie pour l'instant.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-pad-sm bg-surface">
      <div class="container-site max-w-2xl text-center">
        <h2 class="font-display text-2xl font-medium text-ink mb-4">
          Votre projet pourrait être ici.
        </h2>
        <p class="text-sm text-ink-2 mb-6 leading-relaxed">
          Commencez par la Session Découverte Signature à 190 € HT —
          un premier résultat concret sans engagement long terme.
        </p>
        <a href="/contact?offre=session-decouverte" class="btn-primary">
          Démarrer avec une session découverte
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .filter-btn {
    color: theme('colors.ink-2');
    border-color: theme('colors.border');
    background-color: transparent;
  }
  .filter-btn:hover {
    color: theme('colors.ink');
    background-color: theme('colors.surface');
  }
  .filter-btn[aria-pressed="true"] {
    background-color: theme('colors.ink');
    color: theme('colors.white');
    border-color: theme('colors.ink');
  }
  .portfolio-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .portfolio-item.hidden-item {
    display: none;
  }
</style>

<script>
  // (Re)lié à chaque chargement — compatible Astro View Transitions
  function initPortfolioFilters() {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.portfolio-item');
    const noResults = document.getElementById('no-results');
    if (!filterBtns.length) return;

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        filterBtns.forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');

        let visible = 0;
        items.forEach((item) => {
          const cat = item.dataset.categorie;
          const show = filter === 'all' || cat === filter;
          item.classList.toggle('hidden-item', !show);
          if (show) visible++;
        });

        noResults?.classList.toggle('hidden', visible > 0);
      });
    });
  }

  document.addEventListener('astro:page-load', initPortfolioFilters);
</script>
