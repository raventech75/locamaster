---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Hero from '../sections/Hero.astro';
import Positionnement from '../sections/Positionnement.astro';
import Services from '../sections/Services.astro';
import SectorsGrid from '../components/SectorsGrid.astro';
import StatsBand from '../sections/StatsBand.astro';
import SessionDecouverte from '../sections/SessionDecouverte.astro';
import Offres from '../sections/Offres.astro';
import Process from '../sections/Process.astro';
import PourquoiLocamaster from '../sections/PourquoiLocamaster.astro';
import PortfolioPreview from '../sections/PortfolioPreview.astro';
import CasUsage from '../sections/CasUsage.astro';
import FAQ from '../sections/FAQ.astro';
import CTAFinale from '../sections/CTAFinale.astro';
import Temoignages from '../sections/Temoignages.astro';
import LeadMagnet from '../components/LeadMagnet.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Locamaster — Branding, photo et vidéo pour les commerces locaux en Île-de-France",
  "description": "Studio visuel solo pour restaurateurs, fleuristes, libraires, coiffeurs et tous les professionnels locaux. Photo pro, vidéos réseaux, branding complet. Île-de-France.",
  "url": "https://locamaster.fr",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "Locamaster",
    "description": "Branding, photo et vidéo pour les commerces et professionnels locaux en Île-de-France."
  }
};
---

<BaseLayout
  title="Locamaster — Branding, photo et vidéo pour les commerces locaux en Île-de-France"
  description="Studio visuel solo pour restaurateurs, fleuristes, libraires, coiffeurs et tous les professionnels locaux. Photo professionnelle, vidéos réseaux sociaux, branding complet. Île-de-France."
  schema={schema}
>
  <Navigation variant="transparent" />
  <main id="main-content">
    <Hero />
    <Positionnement />
    <Services />
    <SectorsGrid />
    <StatsBand />
    <SessionDecouverte />
    <Process />
    <PourquoiLocamaster />
    <PortfolioPreview />
    <Temoignages />
    <Offres />
    <CasUsage />
    <FAQ />
    <LeadMagnet />
    <CTAFinale />
  </main>
  <Footer />
</BaseLayout>
