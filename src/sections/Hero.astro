---
// Hero — statement éditorial bold, fond clair, accent miel
// Image de contexte artisan à droite, typographie oversized à gauche
import FloatingShapes from '../components/FloatingShapes.astro';
import HeroAnimation from '../components/HeroAnimation.astro';
---

<section
  data-hero
  class="relative bg-bg overflow-hidden"
  aria-label="Présentation Locamaster"
>
  <!-- Grain / texture de fond subtile -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.4]" aria-hidden="true"
       style="background-image: radial-gradient(circle at 1px 1px, rgba(21,18,13,0.06) 1px, transparent 0); background-size: 28px 28px;"></div>

  <!-- Formes flottantes d'ambiance (derrière le contenu) -->
  <FloatingShapes />

  <div class="container-site relative pt-28 md:pt-32 lg:pt-36 pb-0">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-8 items-end">

      <!-- Colonne texte -->
      <div class="lg:col-span-7 pb-12 lg:pb-20">
        <!-- Pill statut -->
        <div data-hero-el class="inline-flex items-center gap-2 mb-7 px-3.5 py-1.5 rounded-full border-2 border-ink">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse" aria-hidden="true"></span>
          <span class="text-2xs font-bold tracking-widest uppercase">Studio visuel · Île-de-France</span>
        </div>

        <!-- Titre oversized -->
        <h1 data-hero-el class="font-display font-bold text-ink tracking-tightest leading-[0.92] mb-7">
          Votre savoir-faire<br />
          mérite d'être <span class="whitespace-nowrap"><span class="highlight">vu</span>.</span>
        </h1>

        <!-- Sous-titre -->
        <p data-hero-el class="text-lg md:text-xl text-ink-2 max-w-lg leading-relaxed mb-9">
          Branding, photo et vidéo pour artisans et entreprises
          locales. On transforme votre métier en image qui fait
          <strong class="text-ink font-semibold">signer vos clients</strong>.
        </p>

        <!-- CTAs -->
        <div data-hero-el class="flex flex-wrap gap-3 mb-10">
          <a href="/contact" data-magnetic class="btn-accent text-base px-8 py-4">
            Demander un devis
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/realisations" data-magnetic class="btn-secondary text-base px-8 py-4">
            Voir les réalisations
          </a>
        </div>

        <!-- Métriques -->
        <div data-hero-el class="flex flex-wrap items-center gap-x-8 gap-y-4">
          <div class="flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-ink">190€</span>
            <span class="text-xs text-muted font-medium leading-tight">offre<br/>découverte</span>
          </div>
          <div class="w-px h-9 bg-border" aria-hidden="true"></div>
          <div class="flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-ink">J+5</span>
            <span class="text-xs text-muted font-medium leading-tight">livraison<br/>rapide</span>
          </div>
          <div class="w-px h-9 bg-border" aria-hidden="true"></div>
          <div class="flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-ink">100%</span>
            <span class="text-xs text-muted font-medium leading-tight">solo, sans<br/>intermédiaire</span>
          </div>
        </div>
      </div>

      <!-- Colonne image -->
      <div data-hero-el class="lg:col-span-5 relative">
        <div class="relative rounded-t-3xl overflow-hidden border-2 border-ink border-b-0 aspect-[4/5] lg:aspect-auto lg:h-[560px]">
          <!-- Motion design : écran de studio animé (photo/vidéo) -->
          <HeroAnimation />
          <!-- Badge flottant -->
          <div class="absolute top-5 right-5 bg-bg border-2 border-ink rounded-full px-4 py-2 flex items-center gap-2 shadow-brutal">
            <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.3 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z"/>
            </svg>
            <span class="text-xs font-bold text-ink">Exigence mariage premium</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bandeau défilant secteurs -->
  <div class="relative bg-ink text-bg overflow-hidden py-4 border-y-2 border-ink">
    <div class="flex whitespace-nowrap animate-marquee">
      {Array.from({ length: 2 }).map(() => (
        <div class="flex items-center shrink-0">
          {['Plombiers', 'Menuisiers', 'Cuisinistes', 'Électriciens', 'Rénovation', 'Artisans du bâtiment', 'PME locales', 'Indépendants'].map((mot) => (
            <span class="flex items-center text-sm font-semibold tracking-tight">
              <span class="px-6">{mot}</span>
              <svg class="w-3 h-3 text-accent" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.3 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z"/>
              </svg>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
