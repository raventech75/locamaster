---
// Section différenciation — arguments clés Locamaster
import ShaderBackground from '../components/ShaderBackground.astro';
---

<section class="section-pad bg-ink text-white relative overflow-hidden" aria-labelledby="pourquoi-titre" id="pourquoi">
  <!-- Fond WebGL animé (lignes miel) + voile pour la lisibilité du texte -->
  <ShaderBackground opacity={0.55} />
  <div class="absolute inset-0 bg-ink/55" aria-hidden="true"></div>

  <div class="container-site relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Gauche — texte principal -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="w-10 h-0.5 bg-accent rounded-full" aria-hidden="true" />
          <span class="text-2xs font-sans font-medium tracking-widest uppercase text-accent">Pourquoi Locamaster</span>
        </div>
        <h2 id="pourquoi-titre" class="font-display text-white mb-6 text-balance">
          Pas une agence.<br />Pas une startup.<br />Un vrai professionnel.
        </h2>
        <div class="flex flex-col gap-5 text-white/70 leading-relaxed">
          <p>
            Je viens du monde de la vidéo de mariage premium — un secteur où
            la qualité visuelle et la gestion de la pression sont une obligation,
            pas une option. Cette exigence, je l'applique à chaque projet artisan.
          </p>
          <p>
            Pas d'équipe de 15 personnes qui se renvoient les dossiers.
            Vous avez un seul interlocuteur, du premier appel à la livraison.
            Quelqu'un qui connaît votre métier, comprend vos contraintes
            et produit du contenu qui sert vraiment votre activité.
          </p>
        </div>
      </div>

      <!-- Droite — arguments -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          {
            titre: 'Exigence visuelle réelle',
            texte: 'Formé sur la vidéo de mariage premium — un secteur où la qualité n\'est pas négociable.',
          },
          {
            titre: 'Approche terrain',
            texte: 'Je comprends les métiers artisanaux, les contraintes de chantier et ce qui doit être montré.',
          },
          {
            titre: 'Solo sans intermédiaire',
            texte: 'Vous parlez directement avec celui qui tient la caméra. Pas de déperdition, pas de délai.',
          },
          {
            titre: 'Contenus utiles',
            texte: 'Pas juste esthétiques. Chaque image ou vidéo a un usage concret : devis, réseaux, Google.',
          },
          {
            titre: 'Offres lisibles',
            texte: 'Des tarifs clairs, des livrables précis. Vous savez ce que vous payez avant de signer.',
          },
          {
            titre: 'Évolutif par design',
            texte: 'On commence petit, on construit sur le long terme — abonnement ou pack suivant votre rythme.',
          },
        ].map((arg) => (
          <div class="p-5 rounded-xl border border-white/10 bg-white/5 hover:bg-white/8 hover:border-white/20 transition-all duration-300">
            <h3 class="font-sans font-medium text-white text-sm mb-1.5 leading-snug">
              {arg.titre}
            </h3>
            <p class="text-xs text-white/55 leading-relaxed">{arg.texte}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
