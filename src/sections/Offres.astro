---
import { packs, abonnements, abonnementsVisibilite } from '../data/offres';

interface Props {
  showTitle?: boolean;
}
const { showTitle = true } = Astro.props;
---

<section class="section-pad bg-surface" aria-labelledby="offres-titre" id="offres">
  <div class="container-site">

    <!-- Header -->
    {showTitle && (
      <div class="text-center max-w-2xl mx-auto mb-14">
        <div class="flex items-center justify-center gap-3 mb-5">
          <span class="accent-line" aria-hidden="true" />
          <span class="section-label">Tarifs</span>
          <span class="accent-line" aria-hidden="true" />
        </div>
        <h2 id="offres-titre" class="font-display text-ink mb-4">
          Des offres lisibles,<br />sans surprise.
        </h2>
        <p class="text-lead">
          Chaque projet peut être ajusté selon le besoin réel.
          Ces packs sont des bases calibrées, pas des cartes rigides.
        </p>
      </div>
    )}

    <!-- ── 1. Packs création one-shot ── -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-2">
        <span class="w-6 h-6 rounded-md bg-accent flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg class="w-3.5 h-3.5 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </span>
        <h3 class="font-display text-xl font-medium text-ink">Packs création visuelle</h3>
      </div>
      <p class="text-sm text-muted mb-8 ml-9">Une intervention complète, un livrable final. Idéal pour démarrer ou refondre votre image.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {packs.map((pack) => (
          <div
            class:list={[
              'relative flex flex-col rounded-xl border transition-all duration-300',
              pack.highlight
                ? 'bg-ink border-ink text-white shadow-lg scale-[1.02]'
                : 'bg-white border-border hover:border-accent/30 hover:shadow-md',
            ]}
          >
            {pack.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="bg-accent text-ink text-2xs font-sans font-medium tracking-widest uppercase px-4 py-1.5 rounded-full whitespace-nowrap shadow-accent">
                  {pack.badge}
                </span>
              </div>
            )}
            <div class="p-7 flex flex-col flex-1 gap-5">
              <div class={pack.badge ? 'pt-2' : ''}>
                <h4 class:list={['font-display text-xl font-medium leading-tight mb-1', pack.highlight ? 'text-white' : 'text-ink']}>
                  {pack.nom}
                </h4>
              </div>
              <div>
                <div class="flex items-baseline gap-2 mb-1">
                  <span class:list={['font-display text-3xl font-medium', pack.highlight ? 'text-white' : 'text-ink']}>
                    {pack.tarifLancement.toLocaleString('fr-FR')} €
                  </span>
                  <span class:list={['text-xs font-sans', pack.highlight ? 'text-white/60' : 'text-muted']}>HT</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class:list={['text-xs line-through', pack.highlight ? 'text-white/40' : 'text-muted']}>
                    conseillé {pack.tarif.toLocaleString('fr-FR')} €
                  </span>
                  <span class="badge text-2xs">Prix lancement</span>
                </div>
              </div>
              <ul class="flex flex-col gap-2.5 flex-1" role="list">
                {pack.livrables.map((livrable) => (
                  <li class:list={['flex items-start gap-2.5 text-sm', pack.highlight ? 'text-white/80' : 'text-ink-2']}>
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {livrable}
                  </li>
                ))}
              </ul>
              <a
                href={`/contact?offre=${pack.id}`}
                class:list={[
                  'mt-auto text-center py-3 px-6 rounded font-sans font-medium text-sm transition-all duration-200',
                  pack.highlight
                    ? 'bg-accent text-ink hover:bg-accent-hover shadow-accent'
                    : 'bg-surface text-ink border border-border hover:border-accent hover:text-accent',
                ]}
              >
                Demander ce pack
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── 2. Abonnements contenu ── -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-2">
        <span class="w-6 h-6 rounded-md bg-accent flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg class="w-3.5 h-3.5 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </span>
        <h3 class="font-display text-xl font-medium text-ink">Contenu mensuel</h3>
      </div>
      <p class="text-sm text-muted mb-8 ml-9">Photos et vidéos livrées chaque mois. Engagement minimum 3 mois.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {abonnements.map((abo) => (
          <div
            class:list={[
              'relative flex flex-col rounded-xl border transition-all duration-300',
              abo.highlight
                ? 'bg-ink border-ink text-white shadow-lg scale-[1.02]'
                : 'bg-white border-border hover:border-accent/30 hover:shadow-md',
            ]}
          >
            {abo.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="bg-accent text-ink text-2xs font-sans font-medium tracking-widest uppercase px-4 py-1.5 rounded-full whitespace-nowrap shadow-accent">
                  {abo.badge}
                </span>
              </div>
            )}
            <div class="p-7 flex flex-col flex-1 gap-5">
              <div class={abo.badge ? 'pt-2' : ''}>
                <h4 class:list={['font-display text-xl font-medium leading-tight mb-1', abo.highlight ? 'text-white' : 'text-ink']}>
                  {abo.nom}
                </h4>
              </div>
              <div>
                <div class="flex items-baseline gap-2 mb-1">
                  <span class:list={['font-display text-3xl font-medium', abo.highlight ? 'text-white' : 'text-ink']}>
                    {abo.tarifLancement.toLocaleString('fr-FR')} €
                  </span>
                  <span class:list={['text-xs font-sans', abo.highlight ? 'text-white/60' : 'text-muted']}>HT / mois</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class:list={['text-xs line-through', abo.highlight ? 'text-white/40' : 'text-muted']}>
                    conseillé {abo.tarif.toLocaleString('fr-FR')} €
                  </span>
                  <span class="badge text-2xs">Prix lancement</span>
                </div>
              </div>
              <ul class="flex flex-col gap-2.5 flex-1" role="list">
                {abo.livrables.map((livrable) => (
                  <li class:list={['flex items-start gap-2.5 text-sm', abo.highlight ? 'text-white/80' : 'text-ink-2']}>
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {livrable}
                  </li>
                ))}
              </ul>
              <a
                href={`/contact?offre=${abo.id}`}
                class:list={[
                  'mt-auto text-center py-3 px-6 rounded font-sans font-medium text-sm transition-all duration-200',
                  abo.highlight
                    ? 'bg-accent text-ink hover:bg-accent-hover shadow-accent'
                    : 'bg-surface text-ink border border-border hover:border-accent hover:text-accent',
                ]}
              >
                Souscrire
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── 3. Visibilité & Publicité ── -->
    <div>
      <div class="flex items-center gap-3 mb-2">
        <span class="w-6 h-6 rounded-md bg-accent flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg class="w-3.5 h-3.5 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
        </span>
        <h3 class="font-display text-xl font-medium text-ink">Visibilité & Publicité</h3>
      </div>
      <p class="text-sm text-muted mb-8 ml-9">Fiche Google gérée + campagnes publicitaires locales. Engagement minimum 3 mois.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {abonnementsVisibilite.map((abo) => (
          <div
            class:list={[
              'relative flex flex-col rounded-xl border transition-all duration-300',
              abo.highlight
                ? 'bg-ink border-ink text-white shadow-lg scale-[1.02]'
                : 'bg-white border-border hover:border-accent/30 hover:shadow-md',
            ]}
          >
            {abo.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="bg-accent text-ink text-2xs font-sans font-medium tracking-widest uppercase px-4 py-1.5 rounded-full whitespace-nowrap shadow-accent">
                  {abo.badge}
                </span>
              </div>
            )}
            <div class="p-7 flex flex-col flex-1 gap-5">
              <div class={abo.badge ? 'pt-2' : ''}>
                <h4 class:list={['font-display text-xl font-medium leading-tight mb-1', abo.highlight ? 'text-white' : 'text-ink']}>
                  {abo.nom}
                </h4>
                <p class:list={['text-xs leading-relaxed', abo.highlight ? 'text-white/60' : 'text-muted']}>
                  {abo.description}
                </p>
              </div>
              <div>
                <div class="flex items-baseline gap-2 mb-1">
                  <span class:list={['font-display text-3xl font-medium', abo.highlight ? 'text-white' : 'text-ink']}>
                    {abo.tarifLancement.toLocaleString('fr-FR')} €
                  </span>
                  <span class:list={['text-xs font-sans', abo.highlight ? 'text-white/60' : 'text-muted']}>HT / mois</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class:list={['text-xs line-through', abo.highlight ? 'text-white/40' : 'text-muted']}>
                    conseillé {abo.tarif.toLocaleString('fr-FR')} €
                  </span>
                  <span class="badge text-2xs">Prix lancement</span>
                </div>
              </div>
              <ul class="flex flex-col gap-2.5 flex-1" role="list">
                {abo.livrables.map((livrable) => (
                  <li class:list={['flex items-start gap-2.5 text-sm', abo.highlight ? 'text-white/80' : 'text-ink-2']}>
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {livrable}
                  </li>
                ))}
              </ul>
              {abo.note && (
                <div class:list={[
                  'text-xs px-3 py-2 rounded-lg flex items-start gap-2',
                  abo.highlight ? 'bg-white/10 text-white/70' : 'bg-accent-soft text-accent-text',
                ]}>
                  <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  {abo.note}
                </div>
              )}
              <a
                href={`/contact?offre=${abo.id}`}
                class:list={[
                  'mt-auto text-center py-3 px-6 rounded font-sans font-medium text-sm transition-all duration-200',
                  abo.highlight
                    ? 'bg-accent text-ink hover:bg-accent-hover shadow-accent'
                    : 'bg-surface text-ink border border-border hover:border-accent hover:text-accent',
                ]}
              >
                Souscrire
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Note bas -->
    <p class="text-center text-sm text-muted mt-10">
      Chaque projet peut être ajusté selon le besoin réel. —
      <a href="/contact" class="text-accent hover:text-accent-hover font-medium transition-colors duration-200">
        Discutons de votre situation
      </a>
    </p>
  </div>
</section>
