---
import { services } from '../data/services';

// Icônes inline SVG pour éviter une dépendance externe
const icons: Record<string, string> = {
  brand: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />`,
  camera: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />`,
  play: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  film: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />`,
  quote: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
  calendar: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`,
  map: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />`,
};
---

<section class="section-pad bg-surface" aria-labelledby="services-titre" id="services">
  <div class="container-site">
    <!-- Header -->
    <div class="max-w-2xl mb-14">
      <div class="flex items-center gap-3 mb-5">
        <span class="accent-line" aria-hidden="true" />
        <span class="section-label">Ce que je fais</span>
      </div>
      <h2 id="services-titre" class="font-display text-ink mb-4">
        Une gamme complète,<br />une seule adresse.
      </h2>
      <p class="text-lead">
        De la photo de chantier au film vitrine, en passant par l'identité visuelle —
        tout ce dont un artisan ou une PME locale a besoin pour avoir une image professionnelle.
      </p>
    </div>

    <!-- Grille des services -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {services.map((service) => (
        <div class="group p-6 bg-white rounded-xl border border-border hover:border-accent/30 hover:shadow-md transition-all duration-300 cursor-default">
          <!-- Icône -->
          <div class="w-10 h-10 rounded-lg bg-accent-soft flex items-center justify-center mb-4 group-hover:bg-accent/15 transition-colors duration-300">
            <svg
              class="w-5 h-5 text-accent"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              set:html={icons[service.icone] || icons.camera}
            />
          </div>
          <!-- Contenu -->
          <h3 class="font-display text-base font-medium text-ink mb-2 leading-snug">
            {service.titre}
          </h3>
          <p class="text-sm text-ink-2 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}

      <!-- Card "Sur mesure" -->
      <div class="group p-6 bg-ink rounded-xl border border-ink hover:bg-ink/90 transition-all duration-300 cursor-default">
        <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
        </div>
        <h3 class="font-display text-base font-medium text-white mb-2 leading-snug">
          Projet sur mesure
        </h3>
        <p class="text-sm text-white/65 leading-relaxed mb-4">
          Votre besoin ne rentre pas dans une case ? On en parle et on construit quelque chose qui vous ressemble.
        </p>
        <a href="/contact" class="text-sm text-accent font-medium inline-flex items-center gap-1.5 hover:gap-2.5 transition-all duration-200">
          Discutons-en
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
