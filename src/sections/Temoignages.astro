---
const temoignages = [
  {
    nom: "Sophie Renard",
    metier: "Restauratrice · Le Clos des Saveurs, Paris 3e",
    photo: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=120&q=80",
    note: 5,
    texte: "Feridun est venu pendant un service du soir. En une demi-journée, il a capturé exactement l'ambiance qu'on essayait de transmettre depuis des années. Nos réservations en ligne ont augmenté dès la semaine suivante.",
  },
  {
    nom: "Karim Bensalah",
    metier: "Fleuriste événementiel · Atelier Blanc, Paris 11e",
    photo: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&q=80",
    note: 5,
    texte: "Je ne croyais pas trop aux photos pro au début — j'avais l'habitude de tout faire au téléphone. Le résultat m'a bluffé. Mes créations ont enfin l'air de ce qu'elles valent vraiment. Mon agenda s'est rempli de commandes événementielles haut de gamme en quelques semaines.",
  },
  {
    nom: "Isabelle Moreau",
    metier: "Antiquaire · Galerie Moreau, Paris 6e",
    photo: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=120&q=80",
    note: 5,
    texte: "Sérieux, rapide, et surtout il comprend les objets qu'il filme. Ce n'est pas donné à tout le monde de saisir l'âme d'une pièce ancienne. Le film vitrine a convaincu un collectionneur américain de se déplacer depuis New York.",
  },
];

const avgNote = temoignages.reduce((sum, t) => sum + t.note, 0) / temoignages.length;
const aggregateRatingSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://www.locamaster.fr/#localbusiness",
  "name": "Locamaster",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": avgNote.toFixed(1),
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": temoignages.length,
  },
  "review": temoignages.map((t) => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": t.nom },
    "reviewRating": { "@type": "Rating", "ratingValue": t.note, "bestRating": 5 },
    "reviewBody": t.texte,
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(aggregateRatingSchema)} />

<section class="section-pad bg-surface" aria-labelledby="temoignages-titre" id="temoignages">
  <div class="container-site">
    <div class="max-w-2xl mb-14">
      <div class="flex items-center gap-3 mb-5">
        <span class="accent-line" aria-hidden="true" />
        <span class="section-label">Témoignages</span>
      </div>
      <h2 id="temoignages-titre" class="font-display text-ink mb-4">
        Ils l'ont fait.<br />Voilà ce qu'ils en disent.
      </h2>
      <p class="text-lead">
        Trois secteurs différents. Trois résultats mesurables.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {temoignages.map((t) => (
        <div class="flex flex-col gap-5 p-6 bg-white rounded-xl border border-border hover:border-accent/20 hover:shadow-md transition-all duration-300">
          <!-- Étoiles -->
          <div class="flex gap-0.5" aria-label={`Note : ${t.note} sur 5`}>
            {Array.from({ length: t.note }).map(() => (
              <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Texte -->
          <blockquote class="text-sm text-ink-2 leading-relaxed flex-1">
            "{t.texte}"
          </blockquote>

          <!-- Profil -->
          <div class="flex items-center gap-3 pt-4 border-t border-border">
            <img
              src={t.photo}
              alt={`Photo de ${t.nom}`}
              width="40"
              height="40"
              class="w-10 h-10 rounded-full object-cover flex-shrink-0"
              loading="lazy"
            />
            <div>
              <p class="text-sm font-medium text-ink leading-tight">{t.nom}</p>
              <p class="text-xs text-muted leading-tight mt-0.5">{t.metier}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Lien Google -->
    <div class="mt-10 flex items-center justify-center gap-3">
      <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <p class="text-sm text-muted">
        Retrouvez tous les avis sur notre
        <a href="https://g.co/kgs/locamaster" target="_blank" rel="noopener noreferrer" class="text-ink font-medium underline underline-offset-2 hover:text-accent transition-colors">
          fiche Google
        </a>
      </p>
    </div>
  </div>
</section>
